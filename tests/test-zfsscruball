#!/usr/bin/bash
# test-zfsscruball — Verify pool locking during scrub.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/test-lib.sh"
setup_test_env

# ---------------------------------------------------------------------------
# Mock commands
# ---------------------------------------------------------------------------

zpool() {
    if [[ "$1" == "scrub" && "$2" == "-w" ]]; then
        echo "$3" >> "${ZFSLOCK_TEST_SCRUB_LOG}"
        return 0
    fi
    if [[ "$1" == "list" && "$2" == "-Ho" && "$3" == "name" ]]; then
        echo -e "${_mock_zpool_list:-}"
        return 0
    fi
    return 0
}

ionice() {
    shift
    "$@"
}

export -f zpool ionice

# ---------------------------------------------------------------------------
# Lock-manager mock lives in a temp module directory.
# ---------------------------------------------------------------------------

setup_scrub_mocks() {
    mock_mydir=$(mktemp -d)
    cat > "$mock_mydir/zfslockmanager" <<EOF
zfslock_init() { true; }
zfslock_acquire() {
    echo "\$1 \$2" >> "${ZFSLOCK_TEST_LOCK_LOG}"
    if [[ "\${ZFSLOCK_TEST_CONFLICT:-}" == "\$1" ]]; then return 1; fi
    ZFSLOCK_ID="${ZFSLOCK_TEST_LOCK_DIR}/lock_\${1//\\//_}"
    return 0
}
zfslock_release() { true; }
zfslock_release_all() { true; }
EOF
}

# ---------------------------------------------------------------------------
# Tests
# ---------------------------------------------------------------------------

test_scrub_acquires_pool_lock() {
    echo "=== Scrub acquires pool lock ==="
    local state_dir
    state_dir="$_mock_zfs_state_dir/scrub_normal"
    mkdir -p "$state_dir"
    ZFSLOCK_TEST_LOCK_LOG="$state_dir/lock.log"
    ZFSLOCK_TEST_SCRUB_LOG="$state_dir/scrub.log"
    ZFSLOCK_TEST_LOCK_DIR="$state_dir/locks"
    ZFSLOCK_TEST_CONFLICT=""
    export ZFSLOCK_TEST_LOCK_LOG ZFSLOCK_TEST_SCRUB_LOG ZFSLOCK_TEST_LOCK_DIR ZFSLOCK_TEST_CONFLICT
    mkdir -p "$ZFSLOCK_TEST_LOCK_DIR"
    : > "$ZFSLOCK_TEST_LOCK_LOG"
    : > "$ZFSLOCK_TEST_SCRUB_LOG"
    STATEFILE="$state_dir/state"
    export STATEFILE
    : > "$STATEFILE"

    setup_scrub_mocks
    mydir="$mock_mydir"
    source "$old_mydir/zfsscruball"

    poolarray=(testpool)
    parallel=2
    do_start

    test_start "Acquires write lock on pool before scrubbing"
    if [[ -f "$ZFSLOCK_TEST_LOCK_LOG" ]] && grep -q '^testpool w$' "$ZFSLOCK_TEST_LOCK_LOG"; then
        test_pass
    else
        test_fail "Expected lock log to contain 'testpool w', got $(cat "$ZFSLOCK_TEST_LOCK_LOG" 2>/dev/null)"
    fi

    test_start "Runs zpool scrub after acquiring lock"
    if [[ -f "$ZFSLOCK_TEST_SCRUB_LOG" ]] && grep -q '^testpool$' "$ZFSLOCK_TEST_SCRUB_LOG"; then
        test_pass
    else
        test_fail "Expected scrub log to contain 'testpool', got $(cat "$ZFSLOCK_TEST_SCRUB_LOG" 2>/dev/null)"
    fi

    rm -rf "$mock_mydir"
}

test_scrub_skips_locked_pool() {
    echo "=== Scrub skips locked pool ==="
    local state_dir
    state_dir="$_mock_zfs_state_dir/scrub_conflict"
    mkdir -p "$state_dir"
    ZFSLOCK_TEST_LOCK_LOG="$state_dir/lock.log"
    ZFSLOCK_TEST_SCRUB_LOG="$state_dir/scrub.log"
    ZFSLOCK_TEST_LOCK_DIR="$state_dir/locks"
    ZFSLOCK_TEST_CONFLICT="testpool"
    export ZFSLOCK_TEST_LOCK_LOG ZFSLOCK_TEST_SCRUB_LOG ZFSLOCK_TEST_LOCK_DIR ZFSLOCK_TEST_CONFLICT
    mkdir -p "$ZFSLOCK_TEST_LOCK_DIR"
    : > "$ZFSLOCK_TEST_LOCK_LOG"
    : > "$ZFSLOCK_TEST_SCRUB_LOG"
    STATEFILE="$state_dir/state"
    : > "$STATEFILE"

    setup_scrub_mocks
    mydir="$mock_mydir"
    source "$old_mydir/zfsscruball"

    poolarray=(testpool)
    parallel=2
    do_start

    test_start "Does not scrub a pool that is already locked"
    if [[ ! -s "$ZFSLOCK_TEST_SCRUB_LOG" ]]; then
        test_pass
    else
        test_fail "Expected no scrub calls, got $(cat "$ZFSLOCK_TEST_SCRUB_LOG" 2>/dev/null)"
    fi

    test_start "Does not record skipped pool as completed"
    if [[ ! -s "$STATEFILE" ]]; then
        test_pass
    else
        test_fail "Expected empty state file, got $(cat "$STATEFILE" 2>/dev/null)"
    fi

    rm -rf "$mock_mydir"
}

# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------
old_mydir="$mydir"
test_scrub_acquires_pool_lock
test_scrub_skips_locked_pool
mydir="$old_mydir"

test_summary
teardown_test_env

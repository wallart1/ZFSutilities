#!/usr/bin/bash
# test-zfsscruball — Verify scrub control behavior.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/test-lib.sh"
setup_test_env

# ---------------------------------------------------------------------------
# Mock commands
# ---------------------------------------------------------------------------

zpool() {
    if [[ "$1" == "scrub" && "$2" == "-w" ]]; then
        echo "$3" >> "${ZFSLOCK_TEST_SCRUB_LOG}"
        return 0
    fi
    if [[ "$1" == "scrub" && "$2" == "-p" ]]; then
        echo "$3" >> "${ZFSLOCK_TEST_PAUSE_LOG}"
        return 0
    fi
    if [[ "$1" == "list" && "$2" == "-Ho" && "$3" == "name" ]]; then
        echo -e "${_mock_zpool_list:-}"
        return 0
    fi
    if [[ "$1" == "status" ]]; then
        echo -e "${_mock_zpool_status:-}"
        return 0
    fi
    return 0
}

ionice() {
    shift
    "$@"
}

export -f zpool ionice

# ---------------------------------------------------------------------------
# Tests
# ---------------------------------------------------------------------------

test_scrub_runs_selected_pool() {
    echo "=== Scrub runs on selected pool ==="
    local state_dir
    state_dir="$_mock_zfs_state_dir/scrub_normal"
    mkdir -p "$state_dir"
    ZFSLOCK_TEST_SCRUB_LOG="$state_dir/scrub.log"
    export ZFSLOCK_TEST_SCRUB_LOG
    : > "$ZFSLOCK_TEST_SCRUB_LOG"
    STATEFILE="$state_dir/state"
    export STATEFILE
    : > "$STATEFILE"

    source "$old_mydir/zfsscruball"

    poolarray=(testpool)
    parallel=2
    local output
    output=$(do_start 2>&1)

    test_start "Runs zpool scrub -w on selected pool"
    if [[ -f "$ZFSLOCK_TEST_SCRUB_LOG" ]] && grep -q '^testpool$' "$ZFSLOCK_TEST_SCRUB_LOG"; then
        test_pass
    else
        test_fail "Expected scrub log to contain 'testpool', got $(cat "$ZFSLOCK_TEST_SCRUB_LOG" 2>/dev/null)"
    fi

    test_start "Logs DEBUG message before issuing zpool scrub -w"
    assert_contains "$output" \
        "DEBUG: issuing zpool scrub command: ionice -c3 zpool scrub -w testpool"
}

test_resume_skips_completed_pools() {
    echo "=== Resume skips completed pools ==="
    local state_dir
    state_dir="$_mock_zfs_state_dir/scrub_resume"
    mkdir -p "$state_dir"
    ZFSLOCK_TEST_SCRUB_LOG="$state_dir/scrub.log"
    export ZFSLOCK_TEST_SCRUB_LOG
    : > "$ZFSLOCK_TEST_SCRUB_LOG"
    STATEFILE="$state_dir/state"
    export STATEFILE
    echo "donepool" > "$STATEFILE"
    _mock_zpool_list="donepool\nnewpool"
    _mock_zpool_status="  scan: none requested"
    export _mock_zpool_list _mock_zpool_status

    source "$old_mydir/zfsscruball"

    do_resume

    test_start "Does not scrub a pool recorded as completed"
    if [[ -f "$ZFSLOCK_TEST_SCRUB_LOG" ]] && ! grep -q '^donepool$' "$ZFSLOCK_TEST_SCRUB_LOG"; then
        test_pass
    else
        test_fail "Expected scrub log to not contain 'donepool', got $(cat "$ZFSLOCK_TEST_SCRUB_LOG" 2>/dev/null)"
    fi
}

test_pause_scrubs_in_progress() {
    echo "=== Pause scrubs in progress ==="
    local state_dir
    state_dir="$_mock_zfs_state_dir/scrub_pause"
    mkdir -p "$state_dir"
    ZFSLOCK_TEST_PAUSE_LOG="$state_dir/pause.log"
    export ZFSLOCK_TEST_PAUSE_LOG
    : > "$ZFSLOCK_TEST_PAUSE_LOG"
    _mock_zpool_list="activepool\nnonepool"
    _mock_zpool_status="  scan: scrub in progress since Sun May 10 00:00:00 2026"
    export _mock_zpool_list _mock_zpool_status

    source "$old_mydir/zfsscruball"

    local output
    output=$(do_pause 2>&1)

    test_start "Pauses pools with an in-progress scrub"
    if [[ -f "$ZFSLOCK_TEST_PAUSE_LOG" ]] && grep -q '^activepool$' "$ZFSLOCK_TEST_PAUSE_LOG"; then
        test_pass
    else
        test_fail "Expected pause log to contain 'activepool', got $(cat "$ZFSLOCK_TEST_PAUSE_LOG" 2>/dev/null)"
    fi

    test_start "Logs DEBUG message before issuing zpool scrub -p"
    assert_contains "$output" \
        "DEBUG: issuing zpool scrub command: zpool scrub -p activepool"
}

# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------
old_mydir="$mydir"
test_scrub_runs_selected_pool
test_resume_skips_completed_pools
test_pause_scrubs_in_progress
mydir="$old_mydir"

test_summary
teardown_test_env

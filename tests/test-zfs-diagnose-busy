    reset_mocks
    _mock_zfs_get_values["pool/fs:mounted"]="no"
    _mock_zfs_get_values["pool/fs:receive_resume_token"]="-"
    _mock_zfs_get_values["pool/fs:sharenfs"]="rw=@192.168.1.0/24"
    _mock_zfs_get_values["pool/fs:sharesmb"]="off"
    start_capture
    diagnose_dataset_busy "pool/fs"

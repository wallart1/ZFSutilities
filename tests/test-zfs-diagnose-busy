test_diagnose_fallback() {
    test_start "Fallback message when no cause found"
    reset_mocks
    _mock_zfs_get_values["pool/fs:mounted"]="no"
    _mock_zfs_get_values["pool/fs:receive_resume_token"]="-"
    start_capture
    diagnose_dataset_busy "pool/fs"

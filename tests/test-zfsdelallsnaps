    test_start "No snapshots returns 0"
    local tmpdir output rc=0
    tmpdir=$(_create_helper_dir)
    _write_delsnap_stub "$tmpdir" ""

    output=$(
        mydir="$tmpdir"
        bash -c '
            zfs() {
                if [[ "$1" == "list" && "$2" == "-Ho" && "$3" == "name" && "$4" == "-t" && "$5" == "snapshot" ]]; then
                    return 0
                fi
                command zfs "$@"
            }
            export -f zfs
            source "'"$old_mydir"'/zfsdelallsnaps"
            delallsnaps "tank/fs"
        '
    ) || rc=$?

    rm -rf "$tmpdir"
    if [[ $rc -eq 0 ]]; then
        test_pass
    else
        test_fail "Expected rc=0, got rc=$rc output: $output"
    fi
}

# ------------------------------------------------------------------
# Test: Filtered list with no matches returns 0
# ------------------------------------------------------------------
test_filtered_no_match_returns_zero() {
    test_start "Filtered list with no matches returns 0"
    local tmpdir output rc=0
    tmpdir=$(_create_helper_dir)
    _write_delsnap_stub "$tmpdir" ""

    output=$(
        mydir="$tmpdir"
        bash -c '
            zfs() {
                if [[ "$1" == "list" && "$2" == "-Ho" && "$3" == "name" && "$4" == "-t" && "$5" == "snapshot" ]]; then
                    echo "tank/fs@snap1"
                    return 0
                fi
                command zfs "$@"
            }
            export -f zfs
            source "'"$old_mydir"'/zfsdelallsnaps"
            delallsnaps "tank/fs" "nomatch"
        '
    ) || rc=$?

    rm -rf "$tmpdir"
    if [[ $rc -eq 0 ]]; then
        test_pass
    else
        test_fail "Expected rc=0, got rc=$rc output: $output"
    fi
}

test_all_success_returns_zero
test_any_failure_returns_one
test_no_snapshots_returns_zero
test_filtered_no_match_returns_zero

test_summary
rc=$?
teardown_test_env
exit $rc

#!/usr/bin/bash
# test-zfscheckagainst — Verify <offsite> placeholder resolution.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/test-lib.sh"
setup_test_env

old_mydir="$mydir"
mock_mydir=$(mktemp -d)
mydir="$mock_mydir"

# Copy real helpers that zfscheckagainst sources.
cp "$old_mydir/zfsremoveleadingqualifiers" "$mock_mydir/zfsremoveleadingqualifiers"
cp "$old_mydir/bashdebug" "$mock_mydir/bashdebug"

# Stub zfsconfig so we control offsite candidates and checkagainst entries.
cat > "$mock_mydir/zfsconfig" << 'EOF'
# Test-controlled state variables (set by the test before checkagainst runs):
#   _zfscheckagainst_offsite_candidates
#   _zfscheckagainst_checkagainst_lines
zfsconfig_get_offsite_candidates() {
    printf '%s\n' "${_zfscheckagainst_offsite_candidates[@]}"
}
zfsconfig_get_checkagainst() {
    printf '%s\n' "${_zfscheckagainst_checkagainst_lines[@]}"
}
EOF

# Stub zfscommsnap so we can control getcommonsnap return codes.
cat > "$mock_mydir/zfscommsnap" << 'EOF'
# Test-controlled state variables (set by the test before checkagainst runs):
#   _getcommonsnap_rc        default rc when no sequence is active
#   _getcommonsnap_sequence  array of rcs to return on successive calls
#   _getcommonsnap_call      index into _getcommonsnap_sequence
getcommonsnap() {
    if [[ ${#_getcommonsnap_sequence[@]} -gt 0 ]]; then
        local rc=${_getcommonsnap_sequence[$_getcommonsnap_call]}
        ((_getcommonsnap_call++))
        return "$rc"
    fi
    return "${_getcommonsnap_rc:-32}"
}
EOF

# Load the module under test.
source "$old_mydir/zfscheckagainst"

# ------------------------------------------------------------------------------
# Mock zfs/zpool commands.
# ------------------------------------------------------------------------------

# State variables controlled by tests.
_zfscheckagainst_online_pools=()
_zfscheckagainst_existing_datasets=()
_zfscheckagainst_snap_exists=0
_zfscheckagainst_guid="guid-candidate"
_zfscheckagainst_dest_guids=""
_zfscheckagainst_holds=""
_zfscheckagainst_source_snaps=""

reset_mocks() {
    _zfscheckagainst_online_pools=()
    _zfscheckagainst_existing_datasets=()
    _zfscheckagainst_snap_exists=0
    _zfscheckagainst_guid="guid-candidate"
    _zfscheckagainst_dest_guids=""
    _zfscheckagainst_holds=""
    _zfscheckagainst_source_snaps=""
    _getcommonsnap_rc=32
    _getcommonsnap_call=0
    _getcommonsnap_sequence=()
    _zfscheckagainst_offsite_candidates=()
    _zfscheckagainst_checkagainst_lines=("poolA/data 0 <offsite> offsite")
}

set_online_pools() {
    _zfscheckagainst_online_pools=("$@")
}

set_existing_datasets() {
    _zfscheckagainst_existing_datasets=("$@")
}

zpool() {
    if [[ "$1" == "list" && "$2" == "-Ho" && "$3" == "name" ]]; then
        local pool
        for pool in "${_zfscheckagainst_online_pools[@]}"; do
            if [[ "$pool" == "$4" ]]; then
                return 0
            fi
        done
        return 1
    fi
    command zpool "$@"
}

zfs() {
    # Snapshot existence check: "zfs list -t snapshot <snap>" only.
    if [[ "$1" == "list" && "$2" == "-t" && "$3" == "snapshot" && -n "$4" && "$4" != -* ]]; then
        return "$_zfscheckagainst_snap_exists"
    fi
    # Destination GUID list: "zfs list -t snapshot -H -o guid -d1 <dataset>".
    if [[ "$1" == "list" && "$2" == "-t" && "$3" == "snapshot" && "$4" == "-H" && "$5" == "-o" && "$6" == "guid" && "$7" == "-d1" ]]; then
        echo "$_zfscheckagainst_dest_guids"
        return 0
    fi
    if [[ "$1" == "list" && "$2" == "-rt" && "$3" == "filesystem,volume" ]]; then
        local ds
        for ds in "${_zfscheckagainst_existing_datasets[@]}"; do
            if [[ "$ds" == "$4" ]]; then
                return 0
            fi
        done
        return 1
    fi
    if [[ "$1" == "get" && "$2" == "-Hp" && "$3" == "-o" && "$4" == "value" && "$5" == "guid" ]]; then
        echo "$_zfscheckagainst_guid"
        return 0
    fi
    if [[ "$1" == "holds" && "$2" == "-H" && -n "$3" ]]; then
        local _hold_snap="$3" _hold_line
        while IFS= read -r _hold_line; do
            [[ "$_hold_line" == "$_hold_snap"$'\t'* ]] && echo "$_hold_line"
        done <<< "$_zfscheckagainst_holds"
        return 0
    fi
    if [[ "$1" == "list" && "$2" == "-Ht" && "$3" == "snapshot" && "$4" == "-o" && "$5" == "name" && "$6" == "-s" && "$7" == "creation" ]]; then
        echo "$_zfscheckagainst_source_snaps"
        return 0
    fi
    command zfs "$@"
}

export -f zpool zfs

# ------------------------------------------------------------------------------
# Tests
# ------------------------------------------------------------------------------

test_offsite_placeholder_one_online_candidate_found() {
    test_start "<offsite> resolves to one online candidate and finds counterpart"
    reset_mocks
    _zfscheckagainst_offsite_candidates=(z22tb)
    set_online_pools z22tb
    set_existing_datasets z22tb/poolA/data

    local rc=0
    checkagainst "poolA/data@offsite-2025-01-01T10:00-05:00-s" >/dev/null 2>&1 || rc=$?
    assert_rc 0 "$rc"
}


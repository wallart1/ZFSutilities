    set_online_pools z22tb z40tb
    set_existing_datasets z22tb/poolA/data z40tb/poolA/data
    # First candidate returns 64 (no other common snap); second returns 32.
    _getcommonsnap_sequence=(64 32)
    _getcommonsnap_call=0

    local rc=0
    checkagainst "poolA/data@offsite-2025-01-01T10:00-05:00-s" >/dev/null 2>&1 || rc=$?
    assert_rc 0 "$rc"
}


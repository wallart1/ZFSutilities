test_single_node_archives_only_referenced_disks() {
    reset_mocks
    test_start "Single-node: only referenced disks are archived"

    local vmid="220"
    local pve_dir="$_mock_zfs_state_dir/pve6"
    local archive="$_mock_zfs_state_dir/archive6"
    local mount="$_mock_zfs_state_dir/mount6"
    mkdir -p "$archive" "$mount" "$mount/threeamigos/proxmox" \
        "$(dirname "$mount/etc/pve/qemu-server")"
    mkdir -p "$pve_dir"
    cat > "${pve_dir}/${vmid}.conf" << EOF
name: test-vm
scsi0: threeamigos:vm-${vmid}-disk-0,size=10G
scsi1: threeamigos:vm-${vmid}-disk-1,size=10G
EOF
    _mock_zvols_list="threeamigos/proxmox/vm-${vmid}-disk-0 threeamigos/proxmox/vm-${vmid}-disk-1"
    _mock_read_response="${archive}
y
n"

    local out rc
    out=$(run_retire single-node existing "$pve_dir" "$archive" "$mount" "$vmid")
    rc=$?

    if [[ $rc -ne 0 ]]; then
        test_fail "Unexpected exit code $rc; output:\n$out"
        return
    fi

    if [[ "$out" != *"Snapshot to archive: threeamigos/proxmox/vm-${vmid}-disk-0@dailybackup"* ]]; then
        test_fail "Disk 0 not archived; output:\n$out"
        return
    fi
    if [[ "$out" != *"Snapshot to archive: threeamigos/proxmox/vm-${vmid}-disk-1@dailybackup"* ]]; then
        test_fail "Disk 1 not archived; output:\n$out"
        return
    fi

    test_pass
}

test_single_node_warns_on_orphaned_zvol() {
    reset_mocks
    test_start "Single-node: orphaned zvol not in config is skipped with warning"

    local vmid="221"
    local pve_dir="$_mock_zfs_state_dir/pve7"
    local archive="$_mock_zfs_state_dir/archive7"
    local mount="$_mock_zfs_state_dir/mount7"
    mkdir -p "$archive" "$mount" "$mount/threeamigos/proxmox" \
        "$(dirname "$mount/etc/pve/qemu-server")"
    setup_pve_config "$pve_dir" "$vmid" "single-node"
    _mock_zvols_list="threeamigos/proxmox/vm-${vmid}-disk-0 threeamigos/proxmox/vm-${vmid}-disk-9"
    _mock_read_response="${archive}
y
n"

    local out rc
    out=$(run_retire single-node existing "$pve_dir" "$archive" "$mount" "$vmid")
    rc=$?

    if [[ $rc -ne 0 ]]; then
        test_fail "Unexpected exit code $rc; output:\n$out"
        return
    fi

    if [[ "$out" != *"Snapshot to archive: threeamigos/proxmox/vm-${vmid}-disk-0@dailybackup"* ]]; then
        test_fail "Referenced disk 0 not archived; output:\n$out"
        return
    fi
    if [[ "$out" == *"Snapshot to archive: threeamigos/proxmox/vm-${vmid}-disk-9@dailybackup"* ]]; then
        test_fail "Orphaned disk 9 was archived; output:\n$out"
        return
    fi
    if [[ "$out" != *"Orphaned zvol not referenced in config: threeamigos/proxmox/vm-${vmid}-disk-9"* ]]; then
        test_fail "Orphan warning missing; output:\n$out"
        return
    fi

    test_pass
}

test_two_node_prompt_mentions_storage_host() {
    reset_mocks
    test_start "Two-node: archive prompt mentions storage host"

    setup_node_config "two-node"
    NODE_CONF="$_mock_zfs_state_dir/node.conf"
    source "$mydir/08 Two-node/node-lib.sh"

    # Load only the prompt builder so we don't run retire-vm's main body.
    eval "$(sed -n '/^build_archive_prompt() {/,/^}/p' \
        "$mydir/09 ZFS clone support/retire-vm")"

    local prompt
    prompt=$(build_archive_prompt "")

    if [[ "$prompt" == *"(must be on stewie)"* ]]; then
        test_pass
    else
        test_fail "Expected storage-host hint in prompt, got: $prompt"
    fi
}

test_no_error_message_level() {
    reset_mocks
    test_start "No unsanctioned ERROR level appears in output"

    local vmid="223"
    local pve_dir="$_mock_zfs_state_dir/pve9"
    local archive="$_mock_zfs_state_dir/archive9"
    local mount="$_mock_zfs_state_dir/mount9"
    mkdir -p "$archive" "$mount" "$mount/threeamigos/proxmox" \
        "$(dirname "$mount/etc/pve/qemu-server")"
    setup_pve_config "$pve_dir" "$vmid" "single-node"
    _mock_read_response="${archive}
y
n"

    local out rc
    out=$(run_retire single-node existing "$pve_dir" "$archive" "$mount" "$vmid")
    rc=$?

    if [[ $rc -ne 0 ]]; then
        test_fail "Unexpected exit code $rc; output:\n$out"
        return
    fi

    if [[ "$out" == *"ERROR:"* ]]; then
        test_fail "Output contains unsanctioned ERROR level; output:\n$out"
        return
    fi

    test_pass
}

# ------------------------------------------------------------------
# Run
# ------------------------------------------------------------------
test_single_node_uses_existing_snapshot
test_single_node_creates_retire_snapshot
test_two_node_queries_storage_for_snapshot
test_two_node_creates_snapshot_on_storage
test_two_node_fetches_volblocksize_on_storage
test_single_node_archives_only_referenced_disks
test_single_node_warns_on_orphaned_zvol
test_two_node_prompt_mentions_storage_host
test_no_error_message_level

test_summary

test_restartability_partial_uninstall() {
    test_start "rerunning after partial uninstall completes successfully"
    local tmpdir
    _setup_uninstall_env tmpdir
    _clear_mocks

    # Simulate partial uninstall: config/logs remain but version base is gone.
    touch "$tmpdir/etc/profile.d/zfsutilities.sh"
    touch "$tmpdir/etc/sudoers.d/zfsutilities"
    touch "$tmpdir/etc/cron.d/zfsutilities"
    touch "$tmpdir/root/.config/zfsutilities.json"
    touch "$tmpdir/var/log/zfsutilities/session.log"

    export SUDO_USER="testuser"
    export HOME="$tmpdir/home/testuser"
    mkdir -p "$tmpdir/home/testuser"
    getent() {
        if [[ "$1" == "passwd" && "$2" == "testuser" ]]; then
            echo "testuser:x:1000:1000:test:/$tmpdir/home/testuser:/bin/bash"
        fi
    }
    chown() { true; }

    # First run: default mode. Should not fail despite missing version base.
    main --yes >/dev/null 2>&1
    local rc=$?

    local failed=0
    if [[ $rc -ne 0 ]]; then
        failed=1
        echo "    first run returned rc=$rc"
    fi
    if [[ -f "$tmpdir/etc/profile.d/zfsutilities.sh" ]]; then
        failed=1
        echo "    profile file still present after first run"
    fi
    if [[ ! -f "$tmpdir/root/.config/zfsutilities.json" ]]; then
        failed=1
        echo "    config removed in default mode"
    fi

    # Second run with --purge should finish cleanup.
    if [[ $failed -eq 0 ]]; then
        main --yes --purge >/dev/null 2>&1
        rc=$?
        if [[ $rc -ne 0 ]]; then
            failed=1
            echo "    second run returned rc=$rc"
        fi
        if [[ -f "$tmpdir/root/.config/zfsutilities.json" ]]; then
            failed=1
            echo "    config still present after purge"
        fi
        if [[ -f "$tmpdir/var/log/zfsutilities/session.log" ]]; then
            failed=1
            echo "    log still present after purge"
        fi
    fi

    unset -f getent chown 2>/dev/null || true
    unset SUDO_USER HOME

    _teardown_uninstall_env "$tmpdir"

    if [[ $failed -eq 0 ]]; then
        test_pass
    else
        test_fail "restartability on partial uninstall failed"
    fi
}

test_all_nodes_ssh() {
    test_start "--all-nodes runs uninstall on peer host"
    local tmpdir
    _setup_uninstall_env tmpdir
    _clear_mocks

    _make_fake_version "$tmpdir/usr/local/lib/zfsutilities" "1.0.0"
    ln -sfn "versions/1.0.0" "$tmpdir/usr/local/lib/zfsutilities/current"

    cat > "$tmpdir/etc/zfsutilities-node.conf" <<'EOF'
NODE_MODE="two-node"
STORAGE_HOST="storage"
COMPUTE_HOST="compute"
EOF

    export ZFSUTILITIES_NODE_CONF="$tmpdir/etc/zfsutilities-node.conf"

    # Pretend this host is the storage host.
    hostname() {
        if [[ "$1" == "-s" ]]; then
            echo "storage"
        else
            command hostname "$@"
        fi
    }

    export SUDO_USER="testuser"
    export HOME="$tmpdir/home/testuser"
    mkdir -p "$tmpdir/home/testuser"
    getent() {
        if [[ "$1" == "passwd" && "$2" == "testuser" ]]; then
            echo "testuser:x:1000:1000:test:/$tmpdir/home/testuser:/bin/bash"
        fi
    }
    chown() { true; }

    main --yes --all-nodes >/dev/null 2>&1
    local rc=$?
    unset -f hostname getent chown 2>/dev/null || true
    unset SUDO_USER HOME ZFSUTILITIES_NODE_CONF

    local failed=0
    if [[ $rc -ne 0 ]]; then
        failed=1
        echo "    Expected rc=0, got $rc"
    fi
    local found=0
    local call
    for call in "${_ssh_calls[@]}"; do
        if [[ "$call" == *"root@compute"* && "$call" == *"uninstall-zfsutilities"* ]]; then
            found=1
            break
        fi
    done
    if [[ $found -eq 0 ]]; then
        failed=1
        echo "    did not invoke uninstall on peer host"
    fi

    _teardown_uninstall_env "$tmpdir"

    if [[ $failed -eq 0 ]]; then
        test_pass
    else
        test_fail "--all-nodes did not run on peer"
    fi
}


#!/usr/bin/bash
# test-uninstall-zfsutilities — Verify the complete uninstall script.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/test-lib.sh"

setup_test_env

UNINSTALL_SCRIPT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../uninstall-zfsutilities"
[[ -f "$UNINSTALL_SCRIPT" ]] || die "Missing: $UNINSTALL_SCRIPT"

# Source the real uninstall script for direct function tests. rootcheck is
# already mocked by test-lib.sh, so the root check is bypassed.
source "$UNINSTALL_SCRIPT"

# Override the script's built-in ask_yn so tests can drive it with mock_ask_yn.
ask_yn() {
    return "$_mock_ask_yn_rc"
}

# ------------------------------------------------------------------
# Test helpers
# ------------------------------------------------------------------

# Set up a temp environment and configure uninstall paths.
_setup_uninstall_env() {
    local _varname="$1"
    local _tmpdir
    _tmpdir=$(mktemp -d)

    export ZFSUTILITIES_VERSION_BASE="$_tmpdir/usr/local/lib/zfsutilities"
    export ZFSUTILITIES_BASHINIT_LINK="$_tmpdir/root/bashinit"
    export ZFSUTILITIES_PROFILE_FILE="$_tmpdir/etc/profile.d/zfsutilities.sh"
    export ZFSUTILITIES_SUDOERS_FILE="$_tmpdir/etc/sudoers.d/zfsutilities"
    export ZFSUTILITIES_NODE_LIB_LINK="$_tmpdir/usr/local/lib/node-lib.sh"
    export ZFSUTILITIES_TWO_NODE_LIB_LINK="$_tmpdir/usr/local/lib/two-node-lib.sh"
    export ZFSUTILITIES_LOCAL_BIN_DIR="$_tmpdir/usr/local/bin"
    export ZFSUTILITIES_NODE_CONF="$_tmpdir/etc/zfsutilities-node.conf"
    export ZFSUTILITIES_LEGACY_NODE_CONF="$_tmpdir/etc/two-node.conf"
    export ZFSUTILITIES_DEPLOY_CONF="$_tmpdir/etc/zfsutilities-deploy.conf"
    export ZFSUTILITIES_CONFIG_PATH="$_tmpdir/root/.config/zfsutilities.json"
    export ZFSUTILITIES_CONFIG_DIR="$_tmpdir/root/.config/zfsutilities"
    export ZFSUTILITIES_HISTORY_PATH="$_tmpdir/root/.config/zfsutilities-history.json"
    export ZFSUTILITIES_CACHE_DIR="$_tmpdir/root/.cache/zfsutilities"
    export ZFSUTILITIES_LOG_DIR="$_tmpdir/var/log/zfsutilities"
    export ZFSUTILITIES_CRON_FILE="$_tmpdir/etc/cron.d/zfsutilities"
    export ZFSUTILITIES_PROFILE_LOCK_DIR="$_tmpdir/run/lock/zfs/profiles"
    export ZFSUTILITIES_ZFSLOCK_DIR="$_tmpdir/run/lock/zfs"
    export ZFSUTILITIES_SYSTEMD_DIR="$_tmpdir/etc/systemd/system"
    export ZFSUTILITIES_ISCSI_ENCRYPTED_CONF="$_tmpdir/etc/iscsi-encrypted-luns.conf"
    export ZFSUTILITIES_LUKS_KEYFILE="$_tmpdir/root/.luks-key"
    export ZFSUTILITIES_PVE_ISCSI_PLUGIN="$_tmpdir/usr/share/perl5/PVE/Storage/ISCSIPlugin.pm"
    export ZFSUTILITIES_CACHE_WARM_LOG_GLOB="$_tmpdir/var/log/zfs-cache-warm*.log"

    mkdir -p "$_tmpdir/root" "$_tmpdir/etc/profile.d" "$_tmpdir/etc/sudoers.d" \
        "$_tmpdir/etc/cron.d" "$_tmpdir/usr/local/lib" "$_tmpdir/usr/local/bin" \
        "$_tmpdir/etc/systemd/system" \
        "$_tmpdir/run/lock/zfs/profiles" "$_tmpdir/run/lock/zfs" \
        "$_tmpdir/root/.config/zfsutilities" "$_tmpdir/root/.cache/zfsutilities" \
        "$_tmpdir/var/log/zfsutilities"

    printf -v "$_varname" '%s' "$_tmpdir"
}

# Clean up a temp environment and unset overrides.
_teardown_uninstall_env() {
    local tmpdir="$1"
    unset ZFSUTILITIES_VERSION_BASE
    unset ZFSUTILITIES_BASHINIT_LINK
    unset ZFSUTILITIES_PROFILE_FILE
    unset ZFSUTILITIES_SUDOERS_FILE
    unset ZFSUTILITIES_NODE_LIB_LINK
    unset ZFSUTILITIES_TWO_NODE_LIB_LINK
    unset ZFSUTILITIES_LOCAL_BIN_DIR
    unset ZFSUTILITIES_NODE_CONF
    unset ZFSUTILITIES_LEGACY_NODE_CONF
    unset ZFSUTILITIES_DEPLOY_CONF
    unset ZFSUTILITIES_CONFIG_PATH
    unset ZFSUTILITIES_CONFIG_DIR
    unset ZFSUTILITIES_HISTORY_PATH
    unset ZFSUTILITIES_CACHE_DIR
    unset ZFSUTILITIES_LOG_DIR
    unset ZFSUTILITIES_CRON_FILE
    unset ZFSUTILITIES_PROFILE_LOCK_DIR
    unset ZFSUTILITIES_ZFSLOCK_DIR
    unset ZFSUTILITIES_SYSTEMD_DIR
    unset ZFSUTILITIES_ISCSI_ENCRYPTED_CONF
    unset ZFSUTILITIES_LUKS_KEYFILE
    unset ZFSUTILITIES_PVE_ISCSI_PLUGIN
    unset ZFSUTILITIES_CACHE_WARM_LOG_GLOB
    rm -rf "$tmpdir"
}

# Build a minimal fake deployed version.
_make_fake_version() {
    local version_base="$1"
    local version="$2"
    mkdir -p "$version_base/versions/$version/bin"
    mkdir -p "$version_base/versions/$version/lib"
    printf '#!/usr/bin/bash\nexit 0\n' > "$version_base/versions/$version/bin/switch-version"
    chmod +x "$version_base/versions/$version/bin/switch-version"
}

# Record systemctl invocations.
_systemctl_calls=()
systemctl() {
    _systemctl_calls+=("$*")
    return 0
}

# Record ssh invocations.
_ssh_calls=()
_ssh_rc=0
ssh() {
    _ssh_calls+=("$*")
    return "$_ssh_rc"
}

_clear_mocks() {
    _systemctl_calls=()
    _ssh_calls=()
}

# ------------------------------------------------------------------
# Tests
# ------------------------------------------------------------------

test_default_uninstall_removes_software_preserves_config() {
    test_start "default uninstall removes software but preserves config/logs"
    local tmpdir
    _setup_uninstall_env tmpdir
    _clear_mocks

    _make_fake_version "$tmpdir/usr/local/lib/zfsutilities" "1.0.0"
    ln -sfn "versions/1.0.0" "$tmpdir/usr/local/lib/zfsutilities/current"
    ln -sfn "versions/1.0.0/bin/bashinit" "$tmpdir/root/bashinit"
    ln -sfn "versions/1.0.0/lib/node-lib.sh" "$tmpdir/usr/local/lib/node-lib.sh"
    ln -sfn "node-lib.sh" "$tmpdir/usr/local/lib/two-node-lib.sh"
    touch "$tmpdir/etc/profile.d/zfsutilities.sh"
    touch "$tmpdir/etc/sudoers.d/zfsutilities"
    touch "$tmpdir/etc/cron.d/zfsutilities"
    touch "$tmpdir/etc/systemd/system/zfs-keys-unlock.service"
    mkdir -p "$tmpdir/etc/systemd/system/rtslib-fb-targetctl.service.d"
    touch "$tmpdir/root/.config/zfsutilities.json"
    touch "$tmpdir/var/log/zfsutilities/session.log"

    export SUDO_USER="testuser"
    export HOME="$tmpdir/home/testuser"
    mkdir -p "$tmpdir/home/testuser"
    getent() {
        if [[ "$1" == "passwd" && "$2" == "testuser" ]]; then
            echo "testuser:x:1000:1000:test:/$tmpdir/home/testuser:/bin/bash"
        fi
    }
    chown() { true; }

    ( main --yes ) >/dev/null 2>&1
    local rc=$?
    unset -f getent chown 2>/dev/null || true
    unset SUDO_USER HOME

    local failed=0
    if [[ $rc -ne 0 ]]; then
        failed=1
        echo "    Expected rc=0, got $rc"
    fi
    if [[ -d "$tmpdir/usr/local/lib/zfsutilities" ]]; then
        failed=1
        echo "    version base still exists"
    fi
    if [[ -L "$tmpdir/root/bashinit" ]]; then
        failed=1
        echo "    /root/bashinit symlink still present"
    fi
    if [[ ! -f "$tmpdir/root/.config/zfsutilities.json" ]]; then
        failed=1
        echo "    config file was incorrectly removed"
    fi
    if [[ ! -f "$tmpdir/var/log/zfsutilities/session.log" ]]; then
        failed=1
        echo "    log file was incorrectly removed"
    fi
    if [[ -f "$tmpdir/etc/cron.d/zfsutilities" ]]; then
        failed=1
        echo "    cron file still present"
    fi

    _teardown_uninstall_env "$tmpdir"

    if [[ $failed -eq 0 ]]; then
        test_pass
    else
        test_fail "default uninstall did not behave as expected"
    fi
}

test_purge_removes_config_logs_cachewarm() {
    test_start "--purge removes config, logs, history, cron, systemd, cache-warm"
    local tmpdir
    _setup_uninstall_env tmpdir
    _clear_mocks

    _make_fake_version "$tmpdir/usr/local/lib/zfsutilities" "1.0.0"
    ln -sfn "versions/1.0.0" "$tmpdir/usr/local/lib/zfsutilities/current"

    touch "$tmpdir/etc/zfsutilities-node.conf"
    touch "$tmpdir/etc/two-node.conf"
    touch "$tmpdir/etc/zfsutilities-deploy.conf"
    touch "$tmpdir/root/.config/zfsutilities.json"
    touch "$tmpdir/root/.config/zfsutilities/scrub_state.json"
    touch "$tmpdir/root/.config/zfsutilities-history.json"
    touch "$tmpdir/root/.cache/zfsutilities/lock"
    touch "$tmpdir/var/log/zfsutilities/session.log"
    touch "$tmpdir/var/log/zfsutilities/cron.log"
    touch "$tmpdir/etc/iscsi-encrypted-luns.conf"
    touch "$tmpdir/root/.luks-key"
    touch "$tmpdir/usr/local/bin/warm-cache.sh"
    touch "$tmpdir/usr/local/bin/identify-hot-vms.sh"
    touch "$tmpdir/usr/local/bin/monitor-cache.sh"
    touch "$tmpdir/var/log/zfs-cache-warm.log"

    # LUKS keyfile removal is confirmed with ask_yn; mock yes.
    mock_ask_yn 0

    export SUDO_USER="testuser"
    export HOME="$tmpdir/home/testuser"
    mkdir -p "$tmpdir/home/testuser"
    getent() {
        if [[ "$1" == "passwd" && "$2" == "testuser" ]]; then
            echo "testuser:x:1000:1000:test:/$tmpdir/home/testuser:/bin/bash"
        fi
    }
    chown() { true; }

    main --yes --purge >/dev/null 2>&1
    local rc=$?
    unset -f getent chown 2>/dev/null || true
    unset SUDO_USER HOME

    local failed=0
    if [[ $rc -ne 0 ]]; then
        failed=1
        echo "    Expected rc=0, got $rc"
    fi
    for path in \
        "$tmpdir/etc/zfsutilities-node.conf" \
        "$tmpdir/etc/two-node.conf" \
        "$tmpdir/etc/zfsutilities-deploy.conf" \
        "$tmpdir/root/.config/zfsutilities.json" \
        "$tmpdir/root/.config/zfsutilities" \
        "$tmpdir/root/.config/zfsutilities-history.json" \
        "$tmpdir/root/.cache/zfsutilities" \
        "$tmpdir/var/log/zfsutilities" \
        "$tmpdir/etc/iscsi-encrypted-luns.conf" \
        "$tmpdir/root/.luks-key" \
        "$tmpdir/usr/local/bin/warm-cache.sh" \
        "$tmpdir/usr/local/bin/identify-hot-vms.sh" \
        "$tmpdir/usr/local/bin/monitor-cache.sh" \
        "$tmpdir/var/log/zfs-cache-warm.log"
    do
        if [[ -e "$path" || -L "$path" ]]; then
            failed=1
            echo "    remnant still present: $path"
        fi
    done

    _teardown_uninstall_env "$tmpdir"

    if [[ $failed -eq 0 ]]; then
        test_pass
    else
        test_fail "--purge did not remove expected remnants"
    fi
}


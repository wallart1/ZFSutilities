test_interactive_dialog_choices() {
    test_start "interactive dialog maps choices to purge and all-nodes"
    local tmpdir
    _setup_uninstall_env tmpdir

    # Create a minimal two-node config.
    cat > "$tmpdir/etc/zfsutilities-node.conf" <<'EOF'
NODE_MODE="two-node"
STORAGE_HOST="storage"
COMPUTE_HOST="compute"
EOF
    export ZFSUTILITIES_NODE_CONF="$tmpdir/etc/zfsutilities-node.conf"

    DO_PURGE="false"
    DO_ALL_NODES="false"
    DO_YES="false"

    load_uninstall_config
    detect_node_mode

    # Mock read to choose "2" (purge) then "y" (all-nodes).
    local _read_idx=0
    local _read_responses=("2" "y")
    read() {
        local varname=""
        local arg
        for arg in "$@"; do
            [[ "$arg" != -* ]] && varname="$arg"
        done
        if [[ $_read_idx -lt ${#_read_responses[@]} ]]; then
            eval "$varname=\"${_read_responses[$_read_idx]}\""
            ((_read_idx++))
            return 0
        fi
        return 1
    }

    # Mock ask_yn for the final confirmation.
    mock_ask_yn 0

    present_interactive_dialog >/dev/null 2>&1
    local rc=$?
    unset -f read 2>/dev/null || true

    local failed=0
    if [[ $rc -ne 0 ]]; then
        failed=1
        echo "    dialog returned non-zero"
    fi
    if [[ "$DO_PURGE" != "true" ]]; then
        failed=1
        echo "    DO_PURGE not set to true"
    fi
    if [[ "$DO_ALL_NODES" != "true" ]]; then
        failed=1
        echo "    DO_ALL_NODES not set to true"
    fi

    unset ZFSUTILITIES_NODE_CONF
    _teardown_uninstall_env "$tmpdir"

    if [[ $failed -eq 0 ]]; then
        test_pass
    else
        test_fail "interactive dialog did not set mode correctly"
    fi
}


# Replicate the selection logic from deploy-version (lines 266–284)
_test_copy_logic() {
    local src_dir="$1"
    local dest_dir="$2"
    mkdir -p "$dest_dir"

    for script in "$src_dir/"*; do
        [[ -f "$script" ]] || continue
        local name
        name=$(basename "$script")
        [[ "$name" == *.md ]] && continue
        [[ "$name" == .gitignore ]] && continue
        [[ "$name" == installed-programs ]] && continue
        [[ "$name" == PROMPT* ]] && continue
        [[ "$name" == VERSION ]] && continue
        if [[ "$name" == zfsretainpol-* && "$name" != zfsretainpol-default ]]; then
            continue
        fi
        if [[ -x "$script" ]]; then
            install -m 0755 "$script" "$dest_dir/"
            continue
        fi
        if head -c2 "$script" | grep -q '^#!'; then
            install -m 0755 "$script" "$dest_dir/"
        fi
    done
}

test_executable_script_copied() {
    test_start "Executable script is copied"
    local tmpdir=$(mktemp -d)
    echo '#!/bin/bash' > "$tmpdir/myscript"
    chmod +x "$tmpdir/myscript"
    local destdir=$(mktemp -d)
    _test_copy_logic "$tmpdir" "$destdir"
    if [[ -f "$destdir/myscript" && -x "$destdir/myscript" ]]; then
        test_pass
    else
        test_fail "myscript was not copied or not executable"
    fi
    rm -rf "$tmpdir" "$destdir"
}


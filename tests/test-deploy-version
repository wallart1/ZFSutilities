# ------------------------------------------------------------------
# Launcher symlinks (from deploy-version deploy_to_host)
# ------------------------------------------------------------------
_test_symlink_logic() {
    local version_dir="$1"
    mkdir -p "$version_dir/bin"

    rm -f "$version_dir/bin/zfsutilities-gui"
    ln -sfn "../07 GTK + Python/zfsutilities_gui.py" "$version_dir/bin/zfsutilities-gui"

    rm -f "$version_dir/bin/zfsutilities-docs"
    ln -sfn "../07 GTK + Python/docs_viewer.py" "$version_dir/bin/zfsutilities-docs"
}

test_launcher_symlinks_created() {
    test_start "deploy-version creates GUI and docs launcher symlinks"
    local tmpdir=$(mktemp -d)
    _test_symlink_logic "$tmpdir"

    local gui_target docs_target ok=1
    gui_target=$(readlink "$tmpdir/bin/zfsutilities-gui" 2>/dev/null || true)
    docs_target=$(readlink "$tmpdir/bin/zfsutilities-docs" 2>/dev/null || true)

    if [[ ! -L "$tmpdir/bin/zfsutilities-gui" ]]; then
        ok=0
        echo "    zfsutilities-gui symlink missing"
    fi
    if [[ ! -L "$tmpdir/bin/zfsutilities-docs" ]]; then
        ok=0
        echo "    zfsutilities-docs symlink missing"
    fi
    if [[ "$gui_target" != "../07 GTK + Python/zfsutilities_gui.py" ]]; then
        ok=0
        echo "    zfsutilities-gui target wrong: $gui_target"
    fi
    if [[ "$docs_target" != "../07 GTK + Python/docs_viewer.py" ]]; then
        ok=0
        echo "    zfsutilities-docs target wrong: $docs_target"
    fi

    rm -rf "$tmpdir"

    if [[ $ok -eq 1 ]]; then
        test_pass
    else
        test_fail "Launcher symlinks were not created correctly"
    fi
}

test_launcher_symlinks_replace_existing() {
    test_start "deploy-version replaces existing launcher symlinks"
    local tmpdir=$(mktemp -d)
    mkdir -p "$tmpdir/bin"
    ln -s "old-target" "$tmpdir/bin/zfsutilities-gui"
    ln -s "old-target" "$tmpdir/bin/zfsutilities-docs"

    _test_symlink_logic "$tmpdir"

    local gui_target docs_target ok=1
    gui_target=$(readlink "$tmpdir/bin/zfsutilities-gui" 2>/dev/null || true)
    docs_target=$(readlink "$tmpdir/bin/zfsutilities-docs" 2>/dev/null || true)

    if [[ "$gui_target" != "../07 GTK + Python/zfsutilities_gui.py" ]]; then
        ok=0
        echo "    zfsutilities-gui target wrong: $gui_target"
    fi
    if [[ "$docs_target" != "../07 GTK + Python/docs_viewer.py" ]]; then
        ok=0
        echo "    zfsutilities-docs target wrong: $docs_target"
    fi

    rm -rf "$tmpdir"

    if [[ $ok -eq 1 ]]; then
        test_pass
    else
        test_fail "Existing launcher symlinks were not replaced"
    fi
}

test_launcher_symlinks_created
test_launcher_symlinks_replace_existing

# ------------------------------------------------------------------
# Production wiring must be handled by switch-version, not deploy-version
# ------------------------------------------------------------------
test_deploy_version_does_not_wire() {
    test_start "deploy-version does not create production wiring"
    local deploy_script
    deploy_script="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../deploy-version"

    local fail_reason=""
    if grep -qE "setup_bashinit_symlink|setup_path_config|cleanup_old_symlinks" "$deploy_script"; then
        fail_reason="deploy-version still defines/calls wiring helpers"
    elif grep -q "/etc/profile.d/zfsutilities.sh" "$deploy_script"; then
        fail_reason="deploy-version still references profile.d config"
    elif grep -q "/etc/sudoers.d/zfsutilities" "$deploy_script"; then
        fail_reason="deploy-version still references sudoers config"
    elif grep -qE "ln -s[^\n]*(/root/bashinit|/usr/local/lib/node-lib\.sh|/usr/local/lib/two-node-lib\.sh|/usr/local/lib/zfsutilities/bin)" "$deploy_script"; then
        fail_reason="deploy-version still creates production symlinks"
    fi

    if [[ -n "$fail_reason" ]]; then
        test_fail "$fail_reason"
    else
        test_pass
    fi
}

test_deploy_version_does_not_wire

test_summary
teardown_test_env

# ---------------------------------------------------------------------------
# lock-zfs-keys: closes /dev/mapper/keys and unmounts /mnt/ZFSkeys
# ---------------------------------------------------------------------------
test_lock_zfs_keys_closes_mapper() {
    test_start "lock-zfs-keys closes /dev/mapper/keys and unmounts /mnt/ZFSkeys"
    make_mock_env
    touch "$TEST_MOUNT/.mounted"
    touch "$TEST_MAPPER/keys"

    local script_copy
    script_copy=$(mktemp)
    prepare_script "$repo_root/08 Two-node/lock-zfs-keys" "$script_copy"

    run_under_mocks "$script_copy" >/dev/null 2>&1

    if [[ -e "$TEST_MAPPER/keys" ]]; then
        test_fail "mapper still present"
    elif [[ -f "$TEST_MOUNT/.mounted" ]]; then
        test_fail "mount marker still present"
    else
        test_pass
    fi

    rm -rf "$MOCKDIR" "$TEST_MOUNT" "$TEST_MAPPER" "$script_copy"
}

# ---------------------------------------------------------------------------
# lock-zfs-keys: leaves a different udisksd mapper alone
# ---------------------------------------------------------------------------
test_lock_zfs_keys_leaves_udisksd_mapper() {
    test_start "lock-zfs-keys leaves non-/dev/mapper/keys mapper alone"
    make_mock_env
    touch "$TEST_MOUNT/.mounted"
    # Simulate udisksd using a different mapper name
    touch "$TEST_MAPPER/udisks-luks"

    local script_copy
    script_copy=$(mktemp)
    prepare_script "$repo_root/08 Two-node/lock-zfs-keys" "$script_copy"

    run_under_mocks "$script_copy" >/dev/null 2>&1

    if [[ -e "$TEST_MAPPER/udisks-luks" ]]; then
        test_pass
    else
        test_fail "udisks mapper was incorrectly closed"
    fi

    rm -rf "$MOCKDIR" "$TEST_MOUNT" "$TEST_MAPPER" "$script_copy"
}


# ---------------------------------------------------------------------------
# auto-unlock: succeeds when USB and keyfile present
# ---------------------------------------------------------------------------
test_auto_unlock_succeeds_with_usb_and_keyfile() {
    test_start "auto-unlock loads keys when USB and keyfile present"
    make_mock_env
    touch "$KEYFILE"

    cat > "$ENCRYPTED_CONF" <<'EOF'
vm-101-disk-1:/dev/zvol/threeamigos/proxmox/vm-101-disk-1:threeamigos
EOF

    cat > "$MOCKDIR/bin/zfs" <<EOF
#!/bin/bash
if [[ "\$1" == "get" && "\$2" == "keystatus" ]]; then
    if [[ -f "$MOCKDIR/keys-loaded" ]]; then
        echo "available"
    else
        echo "unavailable"
    fi
elif [[ "\$1" == "load-key" ]]; then
    touch "$MOCKDIR/keys-loaded"
fi
exit 0
EOF
    chmod +x "$MOCKDIR/bin/zfs"

    local script_copy
    script_copy=$(mktemp)
    prepare_script "$repo_root/08 Two-node/unlock-zfs-keys-auto" "$script_copy"

    local rc=0
    run_under_mocks "$script_copy" >/dev/null 2>&1 || rc=$?

    if [[ "$rc" -eq 0 ]]; then
        test_pass
    else
        test_fail "expected rc=0, got rc=$rc"
    fi

    rm -rf "$MOCKDIR" "$TEST_MOUNT" "$TEST_MAPPER" "$script_copy"
}

# ---------------------------------------------------------------------------
# auto-unlock: reuses already-mounted /mnt/ZFSkeys
# ---------------------------------------------------------------------------
test_auto_unlock_reuses_existing_mount() {
    test_start "auto-unlock reuses already-mounted /mnt/ZFSkeys"
    make_mock_env
    touch "$KEYFILE"
    touch "$TEST_MOUNT/.mounted"
    touch "$TEST_MOUNT/key1"

    cat > "$ENCRYPTED_CONF" <<'EOF'
vm-101-disk-1:/dev/zvol/threeamigos/proxmox/vm-101-disk-1:threeamigos
EOF

    cat > "$MOCKDIR/bin/zfs" <<'EOF'
#!/bin/bash
if [[ "$1" == "get" && "$2" == "keystatus" ]]; then
    echo "unavailable"
elif [[ "$1" == "load-key" ]]; then
    true
fi
exit 0
EOF
    chmod +x "$MOCKDIR/bin/zfs"

    local script_copy
    script_copy=$(mktemp)
    prepare_script "$repo_root/08 Two-node/unlock-zfs-keys-auto" "$script_copy"

    local rc=0
    run_under_mocks "$script_copy" >/dev/null 2>&1 || rc=$?

    if [[ "$rc" -ne 0 ]]; then
        test_fail "expected rc=0, got rc=$rc"
    elif [[ "$(cryptsetup_open_count)" -ne 0 ]]; then
        test_fail "cryptsetup luksOpen was called despite existing mount"
    else
        test_pass
    fi

    rm -rf "$MOCKDIR" "$TEST_MOUNT" "$TEST_MAPPER" "$script_copy"
}


#!/usr/bin/bash
# test-unlock-zfs-keys — Verify LUKS/ZFS key unlock scripts behavior.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/test-lib.sh"
setup_test_env

repo_root="$mydir"

# Create a temporary mock environment for a single test run.
# Sets global variables: MOCKDIR, TEST_MOUNT, TEST_MAPPER, KEYFILE, ENCRYPTED_CONF
make_mock_env() {
    MOCKDIR=$(mktemp -d)
    TEST_MOUNT=$(mktemp -d)
    TEST_MAPPER=$(mktemp -d)
    KEYFILE="$MOCKDIR/root.luks-key"
    ENCRYPTED_CONF="$MOCKDIR/iscsi-encrypted-luns.conf"
    mkdir -p "$MOCKDIR/bin"

    cat > "$MOCKDIR/bin/blkid" <<EOF
#!/bin/bash
if [[ "\$*" == *"PARTLABEL=ZFSkeys"* ]]; then
    echo "/dev/sdz1"
fi
exit 0
EOF
    chmod +x "$MOCKDIR/bin/blkid"

    cat > "$MOCKDIR/bin/cryptsetup" <<EOF
#!/bin/bash
mkdir -p "$MOCKDIR/cryptsetup-calls"
echo "\$*" >> "$MOCKDIR/cryptsetup-calls/calls"
if [[ "\$1" == "luksOpen" ]]; then
    touch "$TEST_MAPPER/keys"
elif [[ "\$1" == "luksClose" ]]; then
    rm -f "$TEST_MAPPER/keys"
fi
exit 0
EOF
    chmod +x "$MOCKDIR/bin/cryptsetup"

    cat > "$MOCKDIR/bin/mount" <<EOF
#!/bin/bash
mkdir -p "$MOCKDIR/mount-calls"
echo "\$*" >> "$MOCKDIR/mount-calls/calls"
if [[ "\$1" == "LABEL=ZFSkeys" ]]; then
    mkdir -p "\$2"
    touch "\$2/.mounted"
fi
exit 0
EOF
    chmod +x "$MOCKDIR/bin/mount"

    cat > "$MOCKDIR/bin/umount" <<EOF
#!/bin/bash
rm -f "$TEST_MOUNT/.mounted"
exit 0
EOF
    chmod +x "$MOCKDIR/bin/umount"

    cat > "$MOCKDIR/bin/mountpoint" <<EOF
#!/bin/bash
if [[ -f "$TEST_MOUNT/.mounted" ]]; then
    exit 0
fi
exit 1
EOF
    chmod +x "$MOCKDIR/bin/mountpoint"

    cat > "$MOCKDIR/bin/findmnt" <<EOF
#!/bin/bash
if [[ -f "$TEST_MOUNT/.mounted" ]]; then
    echo "$TEST_MAPPER/keys"
fi
exit 0
EOF
    chmod +x "$MOCKDIR/bin/findmnt"

    cat > "$MOCKDIR/bin/sleep" <<'EOF'
#!/bin/bash
exit 0
EOF
    chmod +x "$MOCKDIR/bin/sleep"

    cat > "$MOCKDIR/bin/systemctl" <<'EOF'
#!/bin/bash
exit 0
EOF
    chmod +x "$MOCKDIR/bin/systemctl"

    cat > "$MOCKDIR/bin/targetcli" <<'EOF'
#!/bin/bash
exit 0
EOF
    chmod +x "$MOCKDIR/bin/targetcli"

    cat > "$MOCKDIR/bin/iscsi-add-encrypted-luns" <<EOF
#!/bin/bash
echo "called" > "$MOCKDIR/add-encrypted-luns-called"
exit 0
EOF
    chmod +x "$MOCKDIR/bin/iscsi-add-encrypted-luns"

    cat > "$MOCKDIR/bin/lock-zfs-keys" <<EOF
#!/bin/bash
rm -f "$TEST_MOUNT/.mounted"
rm -f "$TEST_MAPPER/keys"
exit 0
EOF
    chmod +x "$MOCKDIR/bin/lock-zfs-keys"
}

# Make a script copy with paths replaced to point into temp dirs.
prepare_script() {
    local src="$1"
    local dst="$2"
    sed -e "s|/root/.luks-key|$KEYFILE|g" \
        -e "s|/etc/iscsi-encrypted-luns.conf|$ENCRYPTED_CONF|g" \
        -e "s|/mnt/ZFSkeys|$TEST_MOUNT|g" \
        -e "s|/dev/mapper/keys|$TEST_MAPPER/keys|g" \
        -e "s|/usr/local/lib/zfsutilities/bin/lock-zfs-keys|lock-zfs-keys|g" \
        -e "s|/usr/local/lib/zfsutilities/bin/iscsi-add-encrypted-luns|iscsi-add-encrypted-luns|g" \
        "$src" > "$dst"
}

# Run a script under the mock PATH in a subshell.
run_under_mocks() {
    local script="$1"
    shift
    (
        export PATH="$MOCKDIR/bin:$PATH"
        export ZFSUTILITIES_LOG_FILE=""
        export mydir="$repo_root/08 Two-node"
        cd "$repo_root"
        bash "$script" "$@"
    )
}

# Return the number of cryptsetup luksOpen calls seen.
cryptsetup_open_count() {
    if [[ -f "$MOCKDIR/cryptsetup-calls/calls" ]]; then
        grep -c "^luksOpen" "$MOCKDIR/cryptsetup-calls/calls" || true
    else
        echo 0
    fi
}

# ---------------------------------------------------------------------------
# auto-unlock: exits cleanly when USB is absent
# ---------------------------------------------------------------------------
test_auto_unlock_exits_cleanly_when_usb_absent() {
    test_start "auto-unlock exits 0 when USB absent and keyfile present"
    make_mock_env
    touch "$KEYFILE"

    cat > "$MOCKDIR/bin/blkid" <<'EOF'
#!/bin/bash
exit 0
EOF
    chmod +x "$MOCKDIR/bin/blkid"

    local script_copy
    script_copy=$(mktemp)
    prepare_script "$repo_root/08 Two-node/unlock-zfs-keys-auto" "$script_copy"

    local rc=0
    run_under_mocks "$script_copy" >/dev/null 2>&1 || rc=$?

    if [[ "$rc" -eq 0 ]]; then
        test_pass
    else
        test_fail "expected rc=0, got rc=$rc"
    fi

    rm -rf "$MOCKDIR" "$TEST_MOUNT" "$TEST_MAPPER" "$script_copy"
}


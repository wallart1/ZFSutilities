# ---------------------------------------------------------------------------
# Test do_transfer omits snapshot when resuming via -t
# ---------------------------------------------------------------------------

test_do_transfer_resume_omits_snapshot() {
    test_start "do_transfer omits snapshot argument in resume-token mode"

    set_msg_level FATAL
    dryrun='N'
    fs="pool/src/data"
    nextsnap="@snap-d"
    destfs="pool/dest"
    restorefs="/data"

    local saved_zfs
    saved_zfs=$(declare -f zfs)
    local capture_file
    capture_file="$_mock_zfs_state_dir/captured_send_args"
    : > "$capture_file"
    zfs() {
        if [[ "$1" == "send" ]]; then
            echo "$*" >> "$capture_file"
            return 0
        fi
        return 0
    }

    clear_log
    capture_stderr
    do_transfer "-t test-resume-token" "-uv" "N" "0" "resume transfer"
    restore_stderr

    eval "$saved_zfs"

    local captured_send
    captured_send=$(cat "$capture_file" 2>/dev/null)
    if [[ "$captured_send" == "send -t test-resume-token" ]]; then
        test_pass
    else
        test_fail "Expected 'send -t test-resume-token', got '$captured_send'"
    fi
}


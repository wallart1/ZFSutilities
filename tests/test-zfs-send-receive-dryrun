#!/usr/bin/bash
# test-zfs-send-receive-dryrun — Tests dry-run behaviour and helper logic in
# zfs-send-receive.  Inner functions become available only after send-receive
# has been executed once, so the first test bootstraps the function and the
# remaining tests exercise the helpers directly.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/test-lib.sh"

# Prevent re-sourcing bashinit / rootcheck / zfslockmanager / bashsetx inside
# send-receive from overwriting our mocks or enabling xtrace.
source() {
    local expanded="${1/#\~/$HOME}"
    [[ "$expanded" == "$HOME/bashinit" ]] && return 0
    [[ "$expanded" == *"rootcheck" ]] && return 0
    [[ "$expanded" == *"zfslockmanager" ]] && return 0
    [[ "$expanded" == *"bashsetx" ]] && return 0
    builtin source "$@"
}

# Auto-answer 'y' to any interactive read prompt (rollback, resume token, etc.)
read() {
    response="y"
    return 0
}

_TEST_LOG="$_mock_zfs_state_dir/sendrecv.log"

set_msg_level() {
    msg_level="$1"
}

capture_stderr() {
    exec 2>"$_TEST_LOG"
}

restore_stderr() {
    exec 2>&1
}

get_stderr_log() {
    # log_msg is redirected to the per-test log file by test-lib.sh.
    cat "$(get_test_log_file)" 2>/dev/null
}

clear_log() {
    : > "$_TEST_LOG"
    : > "$(get_test_log_file)"
}

reset_mocks() {
    _mock_zfs_fs_list=""
    _mock_zfs_snap_list=""
    _mock_zfs_props=()
    _mock_zfs_snaps=()
    _mock_zfs_datasets=()
    _mock_zfs_snap_lists=()
    _mock_zfs_guid_lists=()
    _mock_zfs_send_size="0"
    _mock_zpool_list=""
    _mock_ask_yn_rc=0
    clear_log
}

# ---------------------------------------------------------------------------
# Bootstrap — run send-receive once with dryrun=Y so inner functions exist.
# ---------------------------------------------------------------------------

test_bootstrap_inner_functions() {
    test_start "Bootstrap: send-receive completes in dry-run mode"

    source "$mydir/zfs-send-receive"

    reset_mocks
    set_msg_level INFO

    _mock_zfs_fs_list="pool/src/data"
    _mock_zfs_props["pool/src/data:origin"]="-"
    _mock_zfs_props["pool/dest/data:origin"]="-"
    _mock_zfs_props["pool/dest/data:receive_resume_token"]="-"
    _mock_zfs_props["pool:available"]="10000000000"
    _mock_zfs_props["pool/src/data@snap1:type"]="snapshot"
    _mock_zfs_props["pool/dest/data@snap1:type"]="snapshot"
    _mock_zfs_datasets["pool/dest/data"]=1
    _mock_zfs_snap_lists["pool/src/data"]="pool/src/data@snap1"
    _mock_zfs_snap_lists["pool/dest/data"]="pool/dest/data@snap1"
    _mock_zfs_guid_lists["pool/src/data"]="guid1"
    _mock_zfs_guid_lists["pool/dest/data"]="guid1"
    _mock_zfs_send_size="1000000"

    # Prevent zfssnapbuild from creating a real snapfile
    nextsnap="@test-2025-06-15T10:00-04:00-d"

    capture_stderr
    send-receive "pool/src" "pool/dest" \
        "dryrun='Y'; autoproceed='Y'; sourcefsremovequalifiers=2" || true
    restore_stderr

    local log
    log=$(get_stderr_log)

    if [[ "$log" == *"Dry-run: Would create snapshot"* && \
          "$log" == *"Dry-run: Would send"* ]]; then
        test_pass
    else
        test_fail "Missing expected dry-run log lines"
    fi
}

# ---------------------------------------------------------------------------
# Test autoproceed='N' prompts once for the dataset list then continues
# ---------------------------------------------------------------------------

test_autoproceed_n_prompts_once() {
    test_start "autoproceed='N' prompts once then processes all datasets"

    reset_mocks
    set_msg_level INFO

    _mock_zfs_fs_list="pool/src/data1
pool/src/data2"
    _mock_zfs_props["pool/src/data1:origin"]="-"
    _mock_zfs_props["pool/src/data2:origin"]="-"
    _mock_zfs_props["pool/dest/data1:origin"]="-"
    _mock_zfs_props["pool/dest/data2:origin"]="-"
    _mock_zfs_props["pool/dest/data1:receive_resume_token"]="-"
    _mock_zfs_props["pool/dest/data2:receive_resume_token"]="-"
    _mock_zfs_props["pool:available"]="10000000000"
    _mock_zfs_props["pool/src/data1@snap1:type"]="snapshot"
    _mock_zfs_props["pool/src/data2@snap1:type"]="snapshot"
    _mock_zfs_props["pool/dest/data1@snap1:type"]="snapshot"
    _mock_zfs_props["pool/dest/data2@snap1:type"]="snapshot"
    _mock_zfs_datasets["pool/dest/data1"]=1
    _mock_zfs_datasets["pool/dest/data2"]=1
    _mock_zfs_snap_lists["pool/src/data1"]="pool/src/data1@snap1"
    _mock_zfs_snap_lists["pool/src/data2"]="pool/src/data2@snap1"
    _mock_zfs_snap_lists["pool/dest/data1"]="pool/dest/data1@snap1"
    _mock_zfs_snap_lists["pool/dest/data2"]="pool/dest/data2@snap1"
    _mock_zfs_guid_lists["pool/src/data1"]="guid1"
    _mock_zfs_guid_lists["pool/src/data2"]="guid2"
    _mock_zfs_guid_lists["pool/dest/data1"]="guid1"
    _mock_zfs_guid_lists["pool/dest/data2"]="guid2"
    _mock_zfs_send_size="1000000"

    nextsnap="@test-2025-06-15T10:00-04:00-d"

    # Count how many times `read` is invoked.  The global override is restored
    # after send-receive so later tests are unaffected.
    local read_calls=0
    read() {
        ((read_calls++))
        response="y"
        return 0
    }

    clear_log
    capture_stderr
    send-receive "pool/src" "pool/dest" \
        "dryrun='Y'; autoproceed='N'; sourcefsremovequalifiers=2" || true
    restore_stderr

    # Restore the test harness read override.
    read() {
        response="y"
        return 0
    }

    local log
    log=$(get_stderr_log)

    if [[ "$read_calls" -ne 1 ]]; then
        test_fail "Expected read to be called once, got $read_calls"
        return
    fi
    if [[ "$log" != *"Processing pool/src/data1"* || "$log" != *"Processing pool/src/data2"* ]]; then
        test_fail "Not all datasets were processed; log='$log'"
        return
    fi
    test_pass
}


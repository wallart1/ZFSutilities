test_handle_commsnap_rc16_autoproceed_warns() {
    test_start "handle_commsnap_rc rc=16 autoproceed=Y logs WARN"

    commsnap="@common"
    autoproceed='Y'
    doincrementals="Y"
    dointermediates="Y"
    dryrun='Y'
    fs="pool/src/data"
    destfs="pool/dest"
    restorefs="/data"
    _mock_zfs_snap_lists["pool/dest/data"]=\
"pool/dest/data@snap3\npool/dest/data@snap2\npool/dest/data@common"
    clear_log
    capture_stderr
    handle_commsnap_rc 16 "$fs" "pool/dest/data"
    local rc=$?
    restore_stderr

    local log
    log=$(get_stderr_log)
    if [[ "$rc" -eq 0 && "$receive_F_option" == "F" && \
          "$log" == *"WARN: autoproceed=Y"* ]]; then
        test_pass
    else
        test_fail "rc=$rc receive_F_option='$receive_F_option' log='$log'"
    fi
}


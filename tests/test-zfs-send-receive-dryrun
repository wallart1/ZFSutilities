# ---------------------------------------------------------------------------
# Test zfsdailybackup EXIT trailer respects ZFSUTILITIES_LOG_INHERIT
# ---------------------------------------------------------------------------

_extract_dailybackup_trailer() {
    local outfile="$1"
    awk '/^_write_trailer\(\) \{/,/^}$/' "$mydir/zfsdailybackup" > "$outfile"
}

_run_dailybackup_trailer() {
    local inherit_flag="$1"
    local logfile="$2"
    local funcfile="$_mock_zfs_state_dir/dailybackup_trailer.sh"
    _extract_dailybackup_trailer "$funcfile"
    (
        ZFSUTILITIES_LOG_FILE="$logfile"
        if [[ "$inherit_flag" == "Y" ]]; then
            ZFSUTILITIES_LOG_INHERIT="Y"
        else
            unset ZFSUTILITIES_LOG_INHERIT
        fi
        SECONDS=42
        source "$funcfile"
        (exit 5)   # set $? to a known value
        _write_trailer
    )
}

test_dailybackup_trailer_written_without_inherit() {
    test_start "zfsdailybackup writes # END trailer when not inheriting log"

    local logfile="$_mock_zfs_state_dir/daily-trailer.log"
    : > "$logfile"
    _run_dailybackup_trailer "N" "$logfile"

    if [[ -f "$logfile" && "$(cat "$logfile")" == *"# END: rc=5, duration=42s"* ]]; then
        test_pass
    else
        test_fail "log='$(cat "$logfile" 2>/dev/null)'"
    fi
}

test_dailybackup_trailer_suppressed_with_inherit() {
    test_start "zfsdailybackup suppresses # END trailer when ZFSUTILITIES_LOG_INHERIT=Y"

    local logfile="$_mock_zfs_state_dir/daily-trailer-inherit.log"

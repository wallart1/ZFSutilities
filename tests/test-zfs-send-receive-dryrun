# ---------------------------------------------------------------------------
# Test handle_commsnap_rc rc=4 destination-exists message
# ---------------------------------------------------------------------------

test_handle_commsnap_rc4_existing_dest() {
    test_start "handle_commsnap_rc rc=4 warns when destination exists"

    reset_mocks
    local fs="pool/src/data"
    _mock_zfs_datasets["pool/dest/data"]=1

    local log rc
    log=$(
        # Save the original mock zfs under a different name, then override it
        # inside this subshell so the parent shell is unaffected.
        __zfs_orig_file="$_mock_zfs_state_dir/zfs_orig_$$"
        declare -f zfs > "$__zfs_orig_file"
        sed 's/^zfs ()/_zfs_orig ()/' "$__zfs_orig_file" > "${__zfs_orig_file}.2"
        source "${__zfs_orig_file}.2"
        rm -f "$__zfs_orig_file" "${__zfs_orig_file}.2"

        zfs() {
            if [[ "$1" == "list" && "$2" == "-H" && "$3" == "-o" && "$4" == "name" && -n "$5" ]]; then
                if [[ -n "${_mock_zfs_datasets[$5]+x}" ]]; then
                    echo "$5"
                    return 0
                fi
                return 1
            fi
            _zfs_orig "$@"
        }
        export -f zfs _zfs_orig

        commsnap="@common"
        autoproceed='Y'
        doincrementals="Y"
        msg_level="INFO"
        clear_log
        handle_commsnap_rc 4 "$fs" "pool/dest/data" >/dev/null 2>&1
        rc=$?
        echo "EXITCODE:$rc"
        cat "$(get_test_log_file)"
    )
    rc=$(echo "$log" | grep -o 'EXITCODE:[0-9]*' | cut -d: -f2)
    log=$(echo "$log" | grep -v '^EXITCODE:')

    if [[ "$rc" -eq 0 && "$log" == *"WARN: No common snapshot found between $fs and pool/dest/data."* ]]; then
        test_pass
    else
        test_fail "rc=$rc log='$log'"
    fi
}


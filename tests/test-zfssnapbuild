#!/usr/bin/bash
# test-zfssnapbuild — Unit tests for zfssnapbuild

source "$(cd "$(dirname "$0")" && pwd)/test-lib.sh"
setup_test_env

source "$mydir/zfssnapbuild"

# Override snapfile path so tests do not collide with root-owned files.
TEST_SNAPFILE="/tmp/zfsnextsnap_test_$$"
buildsnapfilename() { echo "$TEST_SNAPFILE"; }

# =============================================================================
# Tests
# =============================================================================

test_new_snapshot_daily() {
    echo "=== New Snapshot Generation ==="
    rm -f "$TEST_SNAPFILE"
    mock_date "2025-06-15T10:00-04:00" "Sun" "15"
    bucket=""
    local result
    result=$(zfssnapbuild)
    test_start "Daily bucket on Sunday (not 1st)"
    assert_equals "@dailybackup-2025-06-15T10:00-04:00-w" "$result"
}

test_new_snapshot_monthly() {
    rm -f "$TEST_SNAPFILE"
    mock_date "2025-06-01T10:00-04:00" "Sun" "01"
    bucket=""
    local result
    result=$(zfssnapbuild)
    test_start "Monthly bucket on Sunday 1st"
    assert_equals "@dailybackup-2025-06-01T10:00-04:00-m" "$result"
}

test_new_snapshot_weekday() {
    rm -f "$TEST_SNAPFILE"
    mock_date "2025-06-10T10:00-04:00" "Tue" "10"
    bucket=""
    local result
    result=$(zfssnapbuild)
    test_start "Daily bucket on weekday"
    assert_equals "@dailybackup-2025-06-10T10:00-04:00-d" "$result"
}

test_new_snapshot_offsite() {
    rm -f "$TEST_SNAPFILE"
    mock_date "2025-06-10T10:00-04:00" "Tue" "10"
    bucket=""
    local result
    result=$(zfssnapbuild "offsite")
    test_start "Offsite label forces bucket 's'"
    assert_equals "@offsite-2025-06-10T10:00-04:00-s" "$result"
}

test_new_snapshot_custom_label() {
    rm -f "$TEST_SNAPFILE"
    mock_date "2025-06-10T10:00-04:00" "Tue" "10"
    bucket=""
    local result
    result=$(zfssnapbuild "mybackup")
    test_start "Custom label without @ prefix"
    assert_equals "@mybackup-2025-06-10T10:00-04:00-d" "$result"
}

test_new_snapshot_explicit_bucket() {
    rm -f "$TEST_SNAPFILE"
    mock_date "2025-06-10T10:00-04:00" "Tue" "10"
    bucket="w"
    local result
    result=$(zfssnapbuild)
    test_start "Explicit bucket variable respected"
    assert_equals "@dailybackup-2025-06-10T10:00-04:00-w" "$result"
}

test_snapfile_reuse_yes() {
    rm -f "$TEST_SNAPFILE"
    echo "@dailybackup-2025-01-01T00:00-05:00-d" > "$TEST_SNAPFILE"
    mock_ask_yn 0   # yes
    bucket=""
    local result
    result=$(zfssnapbuild)
    test_start "Reuse existing snapfile when user says yes"
    assert_equals "@dailybackup-2025-01-01T00:00-05:00-d" "$result"
}

test_snapfile_reuse_no() {
    rm -f "$TEST_SNAPFILE"
    echo "@dailybackup-2025-01-01T00:00-05:00-d" > "$TEST_SNAPFILE"
    mock_ask_yn 1   # no
    mock_date "2025-06-10T10:00-04:00" "Tue" "10"
    bucket=""
    local result newcontent
    result=$(zfssnapbuild)
    newcontent=$(cat "$TEST_SNAPFILE" 2>/dev/null)
    test_start "Reject reuse and generate new snapshot"
    if [[ "$result" == "@dailybackup-2025-06-10T10:00-04:00-d" && "$newcontent" == "@dailybackup-2025-06-10T10:00-04:00-d" ]]; then
        test_pass
    else
        test_fail "result='$result' snapfile='$newcontent'"
    fi
}

test_removesnapfile() {
    rm -f "$TEST_SNAPFILE"
    echo "test" > "$TEST_SNAPFILE"
    removesnapfile
    test_start "removesnapfile deletes snapfile"
    [[ ! -f "$TEST_SNAPFILE" ]] && test_pass || test_fail "Snapfile should be removed"
}

# =============================================================================
# Main
# =============================================================================

main() {
    test_new_snapshot_daily
    test_new_snapshot_monthly
    test_new_snapshot_weekday
    test_new_snapshot_offsite
    test_new_snapshot_custom_label
    test_new_snapshot_explicit_bucket
    test_snapfile_reuse_yes
    test_snapfile_reuse_no
    test_removesnapfile
    rm -f "$TEST_SNAPFILE"
    teardown_test_env
    test_summary
}

main "$@"

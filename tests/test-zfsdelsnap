        bash -c '
            zfs() {
                if [[ "$1" == "list" && "$2" == "-t" && "$3" == "snapshot" ]]; then
                    return 0
                elif [[ "$1" == "list" && "$2" == "-H" && "$3" == "-o" && "$4" == "clones" ]]; then

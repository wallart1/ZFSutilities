# ------------------------------------------------------------------
# Test: Real zfscheckagainst sources remove_leading_qualifiers
# ------------------------------------------------------------------
test_checkagainst_sources_remove_leading_qualifiers() {
    test_start "Real zfscheckagainst defines remove_leading_qualifiers when called"
    local tmpdir
    tmpdir=$(mktemp -d)

    # Copy the real helper modules that zfscheckagainst sources.
    cp "$old_mydir/zfscheckagainst" "$tmpdir/zfscheckagainst"
    cp "$old_mydir/zfscommsnap" "$tmpdir/zfscommsnap"
    cp "$old_mydir/bashdebug" "$tmpdir/bashdebug"
    cp "$old_mydir/zfsconfig" "$tmpdir/zfsconfig"
    cp "$old_mydir/zfsremoveleadingqualifiers" "$tmpdir/zfsremoveleadingqualifiers"

    local output rc=0
    output=$(
        mydir="$tmpdir"
        bash -c '
            # Minimal mock: only the snapshot-existence check needs to succeed.
            zfs() {
                if [[ "$1" == "list" && "$2" == "-t" && "$3" == "snapshot" ]]; then
                    return 0
                fi
                command zfs "$@"
            }
            source "$mydir/zfscheckagainst"
            checkagainst "pool/fs@snap" >/dev/null 2>&1 || true
            if [[ $(type -t remove_leading_qualifiers) == "function" ]]; then
                echo FUNCTION_DEFINED
            else
                echo FUNCTION_MISSING
            fi
        ' 2>&1
    ) || rc=$?

    if [[ "$output" == *"FUNCTION_DEFINED"* ]]; then
        test_pass
    else
        test_fail "Expected remove_leading_qualifiers to be defined after calling" \
            "zfscheckagainst. rc=$rc output: $output"
    fi

    rm -rf "$tmpdir"
}

test_checkagainst_sources_remove_leading_qualifiers

test_summary
teardown_test_env

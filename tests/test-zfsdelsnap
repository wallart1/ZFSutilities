#!/usr/bin/bash
# test-zfsdelsnap — Verify fatal error when required helpers are missing.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/test-lib.sh"
setup_test_env

old_mydir="$mydir"

# ------------------------------------------------------------------
# Test: Missing zfs-diagnose-busy is fatal
# ------------------------------------------------------------------
test_missing_zfs_diagnose_busy_is_fatal() {
    test_start "Missing zfs-diagnose-busy causes fatal message"
    local tmpdir
    tmpdir=$(mktemp -d)

    # Stub out the other helpers that delsnap sources
    cat > "$tmpdir/zfscheckagainst" << 'EOF'
checkagainst() { true; }
remove_leading_qualifiers() { echo "$2"; }
EOF
    cat > "$tmpdir/zfsdelallholds" << 'EOF'
delallholds() { true; }
EOF
    cat > "$tmpdir/zfslockmanager" << 'EOF'
zfslock_init() { true; }
zfslock_wait_or_resolve() { return 0; }
zfslock_release() { true; }
EOF
    # Intentionally do NOT create zfs-diagnose-busy
    # Provide a stub bashfatal so the test shell does not exit.
    cat > "$tmpdir/bashfatal" << 'EOF'
#!/usr/bin/bash
exit ${1:-8}
EOF

    # Run delsnap in a subshell so a fatal exit does not kill the test runner.
    local output rc=0
    output=$(
        mydir="$tmpdir"
        bash -c "source '$old_mydir/zfsdelsnap'; delsnap 'pool@snap' '0' 'N' 'nocheckagainst'" 2>&1
    ) || rc=$?

    if [[ "$output" == *"FATAL: Required helper $tmpdir/zfs-diagnose-busy is missing."* ]]; then
        test_pass
    else
        test_fail "Expected fatal message about missing helper, got: $output"
    fi

    rm -rf "$tmpdir"
}

# ------------------------------------------------------------------
# Test: Present zfs-diagnose-busy allows normal operation
# ------------------------------------------------------------------
test_present_zfs_diagnose_busy_proceeds() {
    test_start "Present zfs-diagnose-busy allows delsnap to proceed"
    local tmpdir
    tmpdir=$(mktemp -d)

    cat > "$tmpdir/zfscheckagainst" << 'EOF'
checkagainst() { true; }
remove_leading_qualifiers() { echo "$2"; }
EOF
    cat > "$tmpdir/zfsdelallholds" << 'EOF'
delallholds() { true; }
EOF
    cat > "$tmpdir/zfslockmanager" << 'EOF'
zfslock_init() { true; }
zfslock_wait_or_resolve() { return 0; }
zfslock_release() { true; }
EOF
    cat > "$tmpdir/zfs-diagnose-busy" << 'EOF'
function diagnose_dataset_busy {
    true
}
EOF
    cat > "$tmpdir/bashfatal" << 'EOF'
#!/usr/bin/bash
exit ${1:-8}
EOF

    # Mock zfs so list, clone check and destroy all succeed
    zfs() {
        if [[ "$1" == "list" && "$2" == "-t" && "$3" == "snapshot" ]]; then
            return 0
        elif [[ "$1" == "list" && "$2" == "-H" && "$3" == "-o" && "$4" == "clones" ]]; then
            echo "-"
        elif [[ "$1" == "destroy" ]]; then
            return 0
        else
            command zfs "$@"
        fi
    }
    export -f zfs

    local output rc=0
    output=$(
        mydir="$tmpdir"
        bash -c "source '$old_mydir/zfsdelsnap'; delsnap 'pool@snap' '0' 'N' 'nocheckagainst'" 2>&1
    ) || rc=$?

    unset -f zfs

    if [[ "$output" != *"FATAL: Required helper"* && $rc -eq 0 ]]; then
        test_pass
    else
        test_fail "Expected normal completion, got rc=$rc output: $output"
    fi

    rm -rf "$tmpdir"
}

test_missing_zfs_diagnose_busy_is_fatal
test_present_zfs_diagnose_busy_proceeds


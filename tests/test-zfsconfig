#!/usr/bin/bash
# test-zfsconfig — Verify JSON config helper functions.

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/test-lib.sh"
setup_test_env

source "$mydir/zfsconfig"

ZFSCONFIG_PATH=$(mktemp)
export ZFSCONFIG_PATH
ZFSLOCK_DIR=$(mktemp -d)
export ZFSLOCK_DIR

clear_zfsconfig_cache() {
    unset _ZFSCONFIG_POOLS_CACHE _ZFSCONFIG_OFFSITE_CACHE _ZFSCONFIG_CA_CACHE
}

write_config() {
    cat > "$ZFSCONFIG_PATH" <<EOF
$1
EOF
    clear_zfsconfig_cache
}

# ------------------------------------------------------------------------------
# zfsconfig_get_pools
# ------------------------------------------------------------------------------

test_get_pools_with_string_entries() {
    test_start "String pool entries are emitted as names"
    write_config '{
  "pools": ["tank", "fivebays"]
}'
    mapfile -t result < <(zfsconfig_get_pools)
    assert_equals "tank" "${result[0]}"
    assert_equals "fivebays" "${result[1]}"
    assert_equals "2" "${#result[@]}"
}

test_get_pools_with_dict_entries() {
    test_start "Dict pool entries emit the name field"
    write_config '{
  "pools": [
    {"name": "tank", "offsite_candidate": false},
    {"name": "fivebays", "offsite_candidate": true}
  ]
}'
    mapfile -t result < <(zfsconfig_get_pools)
    assert_equals "tank" "${result[0]}"
    assert_equals "fivebays" "${result[1]}"
    assert_equals "2" "${#result[@]}"
}

test_get_pools_with_mixed_entries() {
    test_start "Mixed string and dict pool entries are handled"
    write_config '{
  "pools": [
    "tank",
    {"name": "fivebays", "offsite_candidate": true}
  ]
}'
    mapfile -t result < <(zfsconfig_get_pools)
    assert_equals "tank" "${result[0]}"
    assert_equals "fivebays" "${result[1]}"
    assert_equals "2" "${#result[@]}"
}

test_get_pools_skips_dict_without_name() {
    test_start "Dict pool entries without a name are skipped"
    write_config '{
  "pools": [
    {"offsite_candidate": true},
    {"name": "fivebays"}
  ]
}'
    mapfile -t result < <(zfsconfig_get_pools)
    assert_equals "fivebays" "${result[0]}"
    assert_equals "1" "${#result[@]}"
}

test_get_pools_missing_key() {
    test_start "Missing pools key yields no pool names"
    write_config '{}'
    local result
    result=$(zfsconfig_get_pools)
    assert_equals "" "$result"
}

test_get_pools_skips_empty_name() {
    test_start "Dict pool entries with empty name are skipped"
    write_config '{
  "pools": [
    {"name": "", "offsite_candidate": true},
    {"name": "tank"}
  ]
}'
    mapfile -t result < <(zfsconfig_get_pools)
    assert_equals "tank" "${result[0]}"
    assert_equals "1" "${#result[@]}"
}

test_get_pools_skips_null_name() {
    test_start "Dict pool entries with null name are skipped"
    write_config '{
  "pools": [
    {"name": null, "offsite_candidate": true},
    {"name": "tank"}
  ]
}'
    mapfile -t result < <(zfsconfig_get_pools)
    assert_equals "tank" "${result[0]}"
    assert_equals "1" "${#result[@]}"
}

# ------------------------------------------------------------------------------
# zfsconfig_get_offsite_candidates
# ------------------------------------------------------------------------------

test_offsite_candidates_with_dict_pools() {
    test_start "Offsite candidates selects pools marked offsite_candidate"
    write_config '{
  "pools": [
    {"name": "tank", "offsite_candidate": false},
    {"name": "z22tb", "offsite_candidate": true}
  ]
}'
    mapfile -t result < <(zfsconfig_get_offsite_candidates)
    assert_equals "z22tb" "${result[0]}"
}

test_offsite_candidates_ignore_string_pools() {
    test_start "String pool entries are not offsite candidates"
    write_config '{
  "pools": ["tank", "z22tb"]
}'
    local result
    result=$(zfsconfig_get_offsite_candidates)
    assert_equals "" "$result"
}

test_offsite_candidates_ignores_missing_pools() {
    test_start "Missing pools key yields no offsite candidates"
    write_config '{}'
    local result
    result=$(zfsconfig_get_offsite_candidates)
    assert_equals "" "$result"
}

# ------------------------------------------------------------------------------
# zfsconfig_get_checkagainst
# ------------------------------------------------------------------------------

test_get_checkagainst_emits_fields() {
    test_start "Checkagainst entries emitted as whitespace fields"
    write_config '{
  "checkagainst": [
    {"dataset": "tank/a", "quals": "1", "counterpart": "backup/a", "label": "offsite"}
  ]
}'
    local result
    result=$(zfsconfig_get_checkagainst)
    assert_equals "tank/a 1 backup/a offsite" "$result"
}

test_get_checkagainst_skips_incomplete_entries() {
    test_start "Incomplete checkagainst entries are skipped"
    write_config '{
  "checkagainst": [
    {"dataset": "tank/a", "quals": "1", "counterpart": "backup/a", "label": "offsite"},
    {"dataset": "incomplete", "counterpart": "backup/incomplete"}
  ]
}'
    local result
    result=$(zfsconfig_get_checkagainst)
    assert_equals "tank/a 1 backup/a offsite" "$result"
}

test_get_checkagainst_defaults_counterpart_to_dash() {
    test_start "Missing counterpart defaults to '-'"
    write_config '{
  "checkagainst": [
    {"dataset": "tank/a", "quals": "0", "label": "offsite"}
  ]
}'
    local result
    result=$(zfsconfig_get_checkagainst)
    assert_equals "tank/a 0 - offsite" "$result"
}

test_get_checkagainst_merges_nested_sections() {
    test_start "Nested checkagainst sections merge with user precedence"
    write_config '{
  "checkagainst": {
    "backup_derived_active": true,
    "offsite_derived_active": true,
    "backup_derived": [
      {"dataset": "tank/a", "quals": "0", "counterpart": "backup/a", "label": "dailybackup"},
      {"dataset": "tank/b", "quals": "0", "counterpart": "backup/b", "label": "dailybackup"}
    ],
    "offsite_derived": [
      {"dataset": "tank/c", "quals": "0", "counterpart": "offsite/c", "label": "offsite"}
    ],
    "user_entries": [
      {"dataset": "tank/a", "quals": "0", "counterpart": "user/a", "label": "dailybackup"}
    ]
  }
}'
    local result
    result=$(zfsconfig_get_checkagainst)
    assert_contains "$result" "tank/a 0 user/a dailybackup"
    assert_contains "$result" "tank/b 0 backup/b dailybackup"
    assert_contains "$result" "tank/c 0 offsite/c offsite"
}

test_get_checkagainst_active_flags_disable_sections() {
    test_start "Derived sections can be disabled via active flags"
    write_config '{
  "checkagainst": {
    "backup_derived_active": false,
    "offsite_derived_active": false,
    "backup_derived": [
      {"dataset": "tank/a", "quals": "0", "counterpart": "backup/a", "label": "dailybackup"}
    ],
    "offsite_derived": [
      {"dataset": "tank/c", "quals": "0", "counterpart": "offsite/c", "label": "offsite"}
    ],
    "user_entries": [
      {"dataset": "tank/u", "quals": "0", "counterpart": "-", "label": "dailybackup"}
    ]
  }
}'
    local result
    result=$(zfsconfig_get_checkagainst)
    assert_equals "tank/u 0 - dailybackup" "$result"
}

test_get_checkagainst_backward_compatible_flat_list() {
    test_start "Flat checkagainst list is treated as user entries"
    write_config '{
  "checkagainst": [
    {"dataset": "tank/a", "quals": "1", "counterpart": "backup/a", "label": "offsite"}
  ]
}'
    local result
    result=$(zfsconfig_get_checkagainst)
    assert_equals "tank/a 1 backup/a offsite" "$result"
}

# ------------------------------------------------------------------------------
# Locking
# ------------------------------------------------------------------------------

test_set_pools_creates_lock_file() {
    test_start "Set pools creates and uses the config lock file"
    write_config '{}'
    rm -f "$ZFSLOCK_DIR/.config.lock"
    zfsconfig_set_pools tank fivebays
    if [[ -f "$ZFSLOCK_DIR/.config.lock" ]]; then
        test_pass
    else
        test_fail "Lock file $ZFSLOCK_DIR/.config.lock was not created"
    fi
}

test_get_pools_uses_shared_lock() {
    test_start "Get pools uses the config lock file"
    write_config '{"pools": ["tank"]}'
    rm -f "$ZFSLOCK_DIR/.config.lock"
    local result
    result=$(zfsconfig_get_pools)
    assert_equals "tank" "$result"
    if [[ ! -f "$ZFSLOCK_DIR/.config.lock" ]]; then
        test_fail "Lock file $ZFSLOCK_DIR/.config.lock was not created"
    fi
}

# ------------------------------------------------------------------------------
# Run tests
# ------------------------------------------------------------------------------

test_get_pools_with_string_entries
test_get_pools_with_dict_entries
test_get_pools_with_mixed_entries
test_get_pools_skips_dict_without_name
test_get_pools_missing_key
test_get_pools_skips_empty_name
test_get_pools_skips_null_name
test_offsite_candidates_with_dict_pools
test_offsite_candidates_ignore_string_pools
test_offsite_candidates_ignores_missing_pools
test_get_checkagainst_emits_fields
test_get_checkagainst_skips_incomplete_entries
test_get_checkagainst_defaults_counterpart_to_dash
test_get_checkagainst_merges_nested_sections
test_get_checkagainst_active_flags_disable_sections
test_get_checkagainst_backward_compatible_flat_list
test_set_pools_creates_lock_file
test_get_pools_uses_shared_lock

rm -f "$ZFSCONFIG_PATH"
rm -rf "$ZFSLOCK_DIR"

test_summary
teardown_test_env

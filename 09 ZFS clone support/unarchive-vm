#!/usr/bin/bash
# unarchive-vm <vmid> [archive_base]
# Restores an archived VM from archive: recreates zvols, Proxmox config,
# and iSCSI infrastructure (two-node).
#
# Install to: /usr/local/lib/zfsutilities/bin/unarchive-vm on BOTH hosts
# Run from:   the compute host (or the storage host directly — delegates via SSH)

source ~/bashinit
bashinit

NODE_LIB="${NODE_LIB:-$(find_zfsutility_script node-lib.sh)}"
source "$NODE_LIB"

source "$(find_zfsutility_script rootcheck)"
rootcheck

MY_HOST=$(hostname -s)
PVE_CONF_DIR="${PVE_CONF_DIR:-/etc/pve/qemu-server}"
JSON_CONFIG="/root/.config/zfsutilities.json"

usage() {
    echo "Usage: unarchive-vm <vmid> [archive_base] [--new-vmid <new_vmid>]"
    echo ""
    echo "  vmid         VM ID of the retired VM to restore"
    echo "  archive_base Optional ZFS dataset that contains the archive"
    echo "               (defaults to the path saved in JSON config)"
    echo "  --new-vmid   Optional new VM ID to use for restored resources"
    echo ""
    echo "If the original vmid is already in use and --new-vmid is not given,"
    echo "you will be prompted for a new VM ID (or cancel)."
    echo ""
    echo "Steps:"
    echo "  1. Discover archived zvols and Proxmox config"
    echo "  2. Verify destination zvols and config do not already exist"
    echo "  3. Restore each zvol with its original volblocksize"
    echo "  4. Rebuild iSCSI backstores and LUNs (two-node)"
    echo "  5. Restore Proxmox config (rewriting disk lines in two-node)"
    echo "  6. Rescan iSCSI (two-node)"
    echo ""
    echo "Example: unarchive-vm 904"
    echo "Example: unarchive-vm 904 temp/archive"
    echo "Example: unarchive-vm 904 temp/archive --new-vmid 910"
    exit 1
}

ask_yn() {
    local prompt="$1"
    local response
    read -rp "$prompt (y/N): " response
    [[ "$response" =~ ^[Yy]$ ]]
}

prompt_new_vmid() {
    local response
    echo ""
    echo "VMID ${VMID} is already in use (config or zvols exist)."
    read -rp "Enter a new VMID to restore as, or leave blank to abort: " response
    if [[ -z "$response" ]]; then
        echo "Aborted."
        exit 0
    fi
    [[ "$response" =~ ^[0-9]+$ ]] || { log_msg "FATAL: new VMID must be a number, got: $response"; exit 1; }
    [[ "$response" != "$VMID" ]] || { log_msg "FATAL: new VMID must differ from the original VMID"; exit 1; }
    NEWVMID="$response"
}

vmid_in_use() {
    local check_vmid="$1"
    local dest_conf="${PVE_CONF_DIR}/${check_vmid}.conf"
    [[ -f "$dest_conf" ]] && return 0

    local found
    if is_single_node; then
        found=$(zfs list -H -t volume -o name 2>/dev/null \
            | grep -E "/proxmox/vm-${check_vmid}-disk-[0-9]+$" \
            | grep -v "^${ARCHIVE_BASE}/" \
            | head -1)
    else
        found=$(ssh root@"$STORAGE_HOST" bash -s "$check_vmid" "$ARCHIVE_BASE" << 'SSHEOF'
VMID="$1"
ARCHIVE_BASE="$2"
zfs list -H -t volume -o name 2>/dev/null \
    | grep -E "/proxmox/vm-${VMID}-disk-[0-9]+$" \
    | grep -v "^${ARCHIVE_BASE}/" \
    | head -1
SSHEOF
        )
    fi
    [[ -n "$found" ]]
}

# --- Read archive_path from JSON config ---
get_json_archive_path() {
    python3 -c "
import json
try:
    with open('$JSON_CONFIG') as f:
        c = json.load(f)
    print(c.get('archive_path', ''), end='')
except:
    pass
"
}

NEWVMID=""
POS_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --new-vmid)
            shift
            NEWVMID="${1:-}"
            [[ -n "$NEWVMID" ]] || usage
            shift
            ;;
        *)
            POS_ARGS+=("$1")
            shift
            ;;
    esac
done

[[ ${#POS_ARGS[@]} -ge 1 && ${#POS_ARGS[@]} -le 2 ]] || usage

VMID="${POS_ARGS[0]}"
ARCHIVE_BASE="${POS_ARGS[1]:-}"

[[ "$VMID" =~ ^[0-9]+$ ]] || { log_msg "FATAL: vmid must be a number, got: $VMID"; exit 1; }
[[ -z "$NEWVMID" || "$NEWVMID" =~ ^[0-9]+$ ]] || { log_msg "FATAL: new-vmid must be a number, got: $NEWVMID"; exit 1; }
[[ -z "$NEWVMID" || "$NEWVMID" != "$VMID" ]] || { log_msg "FATAL: new-vmid must differ from vmid"; exit 1; }
[[ $EUID -eq 0 || ${UNARCHIVE_VM_TEST_NO_ROOT:-0} == "1" ]] || { log_msg "FATAL: Must run as root (use sudo)"; exit 1; }

# --- If not on the compute host, delegate (two-node only) ---
if is_two_node && [[ "$MY_HOST" != "$COMPUTE_HOST" ]]; then
    new_vmid_arg=""
    [[ -n "$NEWVMID" ]] && new_vmid_arg=" --new-vmid '$NEWVMID'"
    REMOTE_SCRIPT=$(remote_zfsutility_script "$COMPUTE_HOST" "unarchive-vm")
    exec ssh -t root@"$COMPUTE_HOST" \
        "$REMOTE_SCRIPT '$VMID' '$ARCHIVE_BASE'${new_vmid_arg}"
fi

echo "=== unarchive-vm ===="
echo "  VM: ${VMID}"
[[ -n "$NEWVMID" && "$NEWVMID" != "$VMID" ]] && echo "  New VM: ${NEWVMID}"
echo ""

# =======================================================================
# Resolve archive base
# =======================================================================

if [[ -z "$ARCHIVE_BASE" ]]; then
    ARCHIVE_BASE=$(get_json_archive_path)
fi

[[ -n "$ARCHIVE_BASE" ]] \
    || { log_msg "FATAL: Archive base path is required (provide as argument or save in JSON config)"; exit 1; }

# Validate the base exists as a ZFS dataset
if is_single_node; then
    if ! zfs list -H -o name "$ARCHIVE_BASE" 2>/dev/null \
            | grep -q "^${ARCHIVE_BASE}$"; then
        { log_msg "FATAL: Not a ZFS dataset: $ARCHIVE_BASE"; exit 1; }
    fi
else
    if ! ssh root@"$STORAGE_HOST" "zfs list -H -o name '$ARCHIVE_BASE' 2>/dev/null \
            | grep -q '^${ARCHIVE_BASE}$'"; then
        { log_msg "FATAL: Not a ZFS dataset on $STORAGE_HOST: $ARCHIVE_BASE"; exit 1; }
    fi
fi

# Get mountpoint of the base dataset
if is_single_node; then
    ARCHIVE_MOUNT=$(zfs get -H -o value mountpoint "$ARCHIVE_BASE")
else
    ARCHIVE_MOUNT=$(ssh root@"$STORAGE_HOST" \
        "zfs get -H -o value mountpoint '$ARCHIVE_BASE'")
fi

# =======================================================================
# Discover archived zvols
# =======================================================================

echo "--- Discovering archive ---"

# Find archived zvol datasets under the archive base
if is_single_node; then
    archived_zvols=$(zfs list -H -t volume -o name -r "$ARCHIVE_BASE" 2>/dev/null \
        | grep -E "^${ARCHIVE_BASE}/.+/proxmox/vm-${VMID}-disk-[0-9]+$" \
        | sort)
else
    archived_zvols=$(ssh root@"$STORAGE_HOST" bash -s "$ARCHIVE_BASE" "$VMID" << 'SSHEOF'
ARCHIVE_BASE="$1"
VMID="$2"
zfs list -H -t volume -o name -r "$ARCHIVE_BASE" 2>/dev/null \
    | grep -E "^${ARCHIVE_BASE}/.+/proxmox/vm-${VMID}-disk-[0-9]+$" \
    | sort
SSHEOF
    ) || { log_msg "FATAL: SSH to $STORAGE_HOST failed"; exit 1; }
fi

[[ -n "$archived_zvols" ]] || { log_msg "FATAL: No archived zvols found for VM ${VMID} under ${ARCHIVE_BASE}"; exit 1; }

# Build arrays of archive datasets and their original zvol paths
declare -a archive_datasets=()
declare -a original_zvols=()
declare -a new_zvols=()
declare -a disk_nums=()

dataset_count=0
while IFS= read -r arc_zvol; do
    # Original zvol path is the suffix after ARCHIVE_BASE/
    orig_zvol="${arc_zvol#${ARCHIVE_BASE}/}"
    disknum=$(echo "$orig_zvol" | grep -oP 'disk-\K[0-9]+$')

    archive_datasets+=("$arc_zvol")
    original_zvols+=("$orig_zvol")
    disk_nums+=("$disknum")
    ((++dataset_count))
done <<< "$archived_zvols"

# Verify sidecar files exist
missing_sidecars=()
for i in "${!archive_datasets[@]}"; do
    vbs_file="${ARCHIVE_MOUNT}/${original_zvols[$i]}.original_volblocksize"
    info_file="${ARCHIVE_MOUNT}/${original_zvols[$i]}.disk_info"
    if is_single_node; then
        [[ -f "$vbs_file" ]] || missing_sidecars+=("$vbs_file")
        [[ -f "$info_file" ]] || missing_sidecars+=("$info_file")
    else
        if ! ssh root@"$STORAGE_HOST" "[[ -f '$vbs_file' ]]"; then
            missing_sidecars+=("$vbs_file")
        fi
        if ! ssh root@"$STORAGE_HOST" "[[ -f '$info_file' ]]"; then
            missing_sidecars+=("$info_file")
        fi
    fi
done

[[ ${#missing_sidecars[@]} -eq 0 ]] \
    || { log_msg "FATAL: Missing sidecar files:" "$(printf '%s\n  ' "${missing_sidecars[@]}")"; exit 1; }

# Resolve new VMID if the original is in use and none was supplied
if [[ -n "$NEWVMID" ]]; then
    if vmid_in_use "$NEWVMID"; then
        { log_msg "FATAL: Requested new VMID ${NEWVMID} is already in use"; exit 1; }
    fi
elif vmid_in_use "$VMID"; then
    while true; do
        prompt_new_vmid
        if ! vmid_in_use "$NEWVMID"; then
            break
        fi
        echo "VMID ${NEWVMID} is also in use."
        NEWVMID=""
    done
fi
NEWVMID="${NEWVMID:-$VMID}"

# Build new zvol paths using the (possibly changed) VMID
for i in "${!original_zvols[@]}"; do
    new_zvols+=("${original_zvols[$i]/%vm-${VMID}-disk-${disk_nums[$i]}/vm-${NEWVMID}-disk-${disk_nums[$i]}}")
done

# Verify destination zvols do not already exist
existing_dest=()
for i in "${!new_zvols[@]}"; do
    if is_single_node; then
        if zfs list -H -o name "${new_zvols[$i]}" 2>/dev/null \
                | grep -q "^${new_zvols[$i]}$"; then
            existing_dest+=("${new_zvols[$i]}")
        fi
    else
        if ssh root@"$STORAGE_HOST" "zfs list -H -o name '${new_zvols[$i]}' 2>/dev/null \
                | grep -q '^${new_zvols[$i]}$'"; then
            existing_dest+=("${new_zvols[$i]}")
        fi
    fi
done

[[ ${#existing_dest[@]} -eq 0 ]] \
    || { log_msg "FATAL: Destination zvols already exist:" "$(printf '%s\n  ' "${existing_dest[@]}")"; exit 1; }

# Verify archived config exists
archived_config="${ARCHIVE_MOUNT}/${PVE_CONF_DIR}/${VMID}.conf"
if is_single_node; then
    [[ -f "$archived_config" ]] || { log_msg "FATAL: Archived config not found: $archived_config"; exit 1; }
else
    if ! ssh root@"$STORAGE_HOST" "[[ -f '$archived_config' ]]"; then
        { log_msg "FATAL: Archived config not found on $STORAGE_HOST: $archived_config"; exit 1; }
    fi
fi

# Verify destination config does not already exist
dest_config="${PVE_CONF_DIR}/${NEWVMID}.conf"
[[ ! -f "$dest_config" ]] || { log_msg "FATAL: Destination Proxmox config already exists: $dest_config"; exit 1; }

# =======================================================================
# Show summary and confirm
# =======================================================================

echo "  Archive base: ${ARCHIVE_BASE}"
echo "  Archive mount: ${ARCHIVE_MOUNT}"
echo "  Archived config: ${archived_config}"
echo "  Zvols to restore:"
for i in "${!archive_datasets[@]}"; do
    vbs_file="${ARCHIVE_MOUNT}/${original_zvols[$i]}.original_volblocksize"
    if is_single_node; then
        orig_vbs=$(cat "$vbs_file")
    else
        orig_vbs=$(ssh root@"$STORAGE_HOST" "cat '$vbs_file'")
    fi
    if [[ "${original_zvols[$i]}" != "${new_zvols[$i]}" ]]; then
        echo "    ${original_zvols[$i]} → ${new_zvols[$i]} (volblocksize: ${orig_vbs})"
    else
        echo "    ${new_zvols[$i]} (volblocksize: ${orig_vbs})"
    fi
done
echo ""

if ! ask_yn "Proceed with restore?"; then
    echo "Aborted."
    exit 0
fi
echo ""

# =======================================================================
# Step 1: Restore zvols
# =======================================================================

echo "--- Step 1: Restoring zvols ---"

if is_single_node; then
    for i in "${!archive_datasets[@]}"; do
        arc_dataset="${archive_datasets[$i]}"
        orig_zvol="${original_zvols[$i]}"
        new_zvol="${new_zvols[$i]}"
        vbs_file="${ARCHIVE_MOUNT}/${orig_zvol}.original_volblocksize"

        snap=$(zfs list -H -t snapshot -o name -S creation "$arc_dataset" 2>/dev/null | head -1)
        [[ -n "$snap" ]] || { log_msg "FATAL: No snapshots found on archive dataset: $arc_dataset"; exit 1; }

        snap_name="@${snap##*@}"
        orig_vbs=$(cat "$vbs_file")

        parent=$(dirname "$new_zvol")
        zfs create -p "$parent" 2>/dev/null || true

        echo "  Restoring ${new_zvol} (volblocksize: ${orig_vbs})..."
        if ! zfs send -cw "${arc_dataset}${snap_name}" \
                | zfs receive -o volblocksize="$orig_vbs" "$new_zvol"; then
            { log_msg "FATAL: Failed to restore ${new_zvol}"; exit 1; }
        fi
        echo "  ✓ Restored: ${new_zvol}"
    done
else
    # Two-node: run restoration on storage host via SSH
    ssh root@"$STORAGE_HOST" bash -s "$ARCHIVE_MOUNT" "$dataset_count" \
        "${archive_datasets[@]}" "${original_zvols[@]}" "${new_zvols[@]}" << 'SSHEOF'
set -e
ARCHIVE_MOUNT="$1"
dataset_count="$2"
shift 2

archive_datasets=("${@:1:$dataset_count}")
original_zvols=("${@:$((dataset_count + 1)):$dataset_count}")
new_zvols=("${@:$((2 * dataset_count + 1)):$dataset_count}")

for i in "${!archive_datasets[@]}"; do
    arc_dataset="${archive_datasets[$i]}"
    orig_zvol="${original_zvols[$i]}"
    new_zvol="${new_zvols[$i]}"
    vbs_file="${ARCHIVE_MOUNT}/${orig_zvol}.original_volblocksize"

    snap=$(zfs list -H -t snapshot -o name -S creation "$arc_dataset" 2>/dev/null | head -1)
    [[ -n "$snap" ]] || { echo "ERROR: No snapshots found on ${arc_dataset}" >&2; exit 1; }

    snap_name="@${snap##*@}"
    orig_vbs=$(cat "$vbs_file")

    parent=$(dirname "$new_zvol")
    zfs create -p "$parent" 2>/dev/null || true

    echo "  Restoring ${new_zvol} (volblocksize: ${orig_vbs})..." >&2
    zfs send -cw "${arc_dataset}${snap_name}" \
        | zfs receive -o volblocksize="$orig_vbs" "$new_zvol"
    echo "  ✓ Restored: ${new_zvol}" >&2
done
SSHEOF
    [[ $? -eq 0 ]] || { log_msg "FATAL: Zvol restoration failed on $STORAGE_HOST"; exit 1; }
fi

echo ""

# =======================================================================
# Step 2: iSCSI reconstruction (two-node only)
# =======================================================================

declare -A disk_to_lun=()
declare -A disk_to_target=()

if is_two_node; then
    echo "--- Step 2: Rebuilding iSCSI infrastructure ---"

    lun_result=$(ssh root@"$STORAGE_HOST" bash -s "$NEWVMID" "$dataset_count" \
        "${new_zvols[@]}" << 'SSHEOF'
set -e
VMID="$1"
dataset_count="$2"
shift 2
new_zvols=("${@:1:$dataset_count}")

for i in "${!new_zvols[@]}"; do
    new_zvol="${new_zvols[$i]}"
    pool="${new_zvol%%/*}"
    disknum=$(echo "$new_zvol" | grep -oP 'disk-\K[0-9]+$')
    backstore="vm-${VMID}-disk-${disknum}"
    zvol_dev="/dev/zvol/${new_zvol}"

    # Map pool to target using node-lib's pool_to_target logic
    target=$(python3 -c "
import json, sys
conf = '/etc/zfsutilities-node.conf'
try:
    with open(conf) as f:
        exec(f.read())
    print(f'{IQN_PREFIX}:{POOL_TARGET[\"'$pool'\"]}')
except Exception as e:
    sys.exit(1)
") || { echo "ERROR: Cannot map pool ${pool} to target" >&2; exit 1; }

    echo "TARGET:${target}"
    echo "DISK:${disknum}"

    # Create backstore if missing
    if targetcli /backstores/block ls 2>/dev/null | grep -q " ${backstore} "; then
        echo "BACKSTORE_EXISTS:${backstore}"
    else
        targetcli /backstores/block create "$backstore" "$zvol_dev"
        targetcli "/backstores/block/${backstore}" set attribute emulate_tpu=1
        echo "BACKSTORE_CREATED:${backstore}"
    fi

    # Create LUN if missing
    existing_lun=$(targetcli "/iscsi/${target}/tpg1/luns" ls 2>/dev/null \
        | grep " ${backstore} " \
        | grep -oP 'lun\K[0-9]+' \
        | head -1)

    if [[ -n "$existing_lun" ]]; then
        echo "LUN_EXISTS:${disknum}:${existing_lun}"
    else
        targetcli "/iscsi/${target}/tpg1/luns" create "/backstores/block/${backstore}"
        new_lun=$(targetcli "/iscsi/${target}/tpg1/luns" ls 2>/dev/null \
            | grep " ${backstore} " \
            | grep -oP 'lun\K[0-9]+' \
            | head -1)
        echo "LUN_CREATED:${disknum}:${new_lun}"
    fi

    # Add to expected-backstores manifest
    manifest="/etc/rtslib-fb-target/expected-backstores.txt"
    if [[ -f "$manifest" ]]; then
        if ! grep -q "^${backstore}$" "$manifest"; then
            echo "$backstore" >> "$manifest"
            echo "MANIFEST_ADDED:${backstore}"
        fi
    fi

    # Check encryption status and add to encrypted-luns.conf if needed
    enc_status=$(zfs get -H -o value encryption "$new_zvol" 2>/dev/null || echo "-")
    if [[ "$enc_status" != "-" && "$enc_status" != "off" ]]; then
        enc_conf="/etc/iscsi-encrypted-luns.conf"
        target_short="${target##*:}"
        if [[ -f "$enc_conf" ]] && grep -q "^${backstore}:" "$enc_conf"; then
            echo "ENCRYPTED_ALREADY:${backstore}"
        else
            echo "${backstore}:${zvol_dev}:${target_short}" >> "$enc_conf"
            echo "ENCRYPTED_ADDED:${backstore}"
        fi
    fi
done

# Save iSCSI config
mydir=$(realpath /usr/local/lib/zfsutilities/current/bin)
"$mydir/safe-iscsi-save"
echo "CONFIG_SAVED"
SSHEOF
    ) || { log_msg "FATAL: iSCSI reconstruction failed on $STORAGE_HOST"; exit 1; }

    # Parse results
    current_target=""
    while IFS= read -r line; do
        case "$line" in
            TARGET:*)
                current_target="${line#TARGET:}"
                ;;
            LUN_EXISTS:*)
                dnum="${line#LUN_EXISTS:}"
                dnum="${dnum%%:*}"
                lun="${line##*:}"
                disk_to_lun["$dnum"]="$lun"
                disk_to_target["$dnum"]="$current_target"
                echo "  ✓ Disk ${dnum}: LUN ${lun} (existing)"
                ;;
            LUN_CREATED:*)
                dnum="${line#LUN_CREATED:}"
                dnum="${dnum%%:*}"
                lun="${line##*:}"
                disk_to_lun["$dnum"]="$lun"
                disk_to_target["$dnum"]="$current_target"
                echo "  ✓ Disk ${dnum}: LUN ${lun} (created)"
                ;;
            CONFIG_SAVED)
                echo "  ✓ iSCSI configuration saved"
                ;;
        esac
    done <<< "$lun_result"
    echo ""
fi

# =======================================================================
# Step 3: Restore Proxmox config
# =======================================================================

echo "--- Step 3: Restoring Proxmox config ---"

mkdir -p "$(dirname "$dest_config")"

# Build disk_key -> disk_num mapping from .disk_info sidecars.
declare -A key_to_disknum=()
for i in "${!original_zvols[@]}"; do
    info_file="${ARCHIVE_MOUNT}/${original_zvols[$i]}.disk_info"
    if is_single_node; then
        disk_key=$(grep '^DISK_KEY=' "$info_file" 2>/dev/null | cut -d= -f2)
    else
        disk_key=$(ssh root@"$STORAGE_HOST" "grep '^DISK_KEY=' '$info_file' 2>/dev/null | cut -d= -f2")
    fi
    disknum="${disk_nums[$i]}"
    [[ -n "$disk_key" ]] && key_to_disknum["$disk_key"]="$disknum"
done

if is_single_node; then
    archived_content=$(cat "$archived_config")
else
    archived_content=$(ssh root@"$STORAGE_HOST" "cat '$archived_config'")
fi
[[ -n "$archived_content" ]] || { log_msg "FATAL: Failed to read archived config"; exit 1; }

rewrite_needed=false
[[ "$NEWVMID" != "$VMID" ]] && rewrite_needed=true

if [[ "$rewrite_needed" == "false" ]] && is_single_node; then
    # No VMID change in single-node mode: simple copy is sufficient.
    cp "$archived_config" "$dest_config"
    echo "  ✓ Config restored: $dest_config"
else
    # Rewrite disk lines (and UUIDs when the VMID changed).
    new_vmgenid=""
    new_smbios_uuid=""
    vmgenid_written=false
    smbios1_written=false
    if [[ "$rewrite_needed" == "true" ]]; then
        new_vmgenid=$(cat /proc/sys/kernel/random/uuid)
        new_smbios_uuid=$(cat /proc/sys/kernel/random/uuid)
    fi

    while IFS= read -r line; do
        [[ "$line" =~ ^\[.+\] ]] && break

        if [[ "$line" =~ \
            ^([a-z]+[0-9]+):\ *([^:]+):vm-${VMID}-disk-([0-9]+)(.*) ]]; then
            # Single-node disk line: rewrite VMID if it changed, otherwise keep.
            key="${BASH_REMATCH[1]}"
            storage="${BASH_REMATCH[2]}"
            disknum="${BASH_REMATCH[3]}"
            rest="${BASH_REMATCH[4]}"
            echo "${key}: ${storage}:vm-${NEWVMID}-disk-${disknum}${rest}"
            [[ "$NEWVMID" != "$VMID" ]] && echo "  ✓ Rewrote ${key} for VMID ${NEWVMID}" >&2
        elif [[ "$line" =~ \
            ^([a-z]+[0-9]+):.*ip-([0-9\.]+):3260-iscsi-(iqn\.[^,]+)-lun-([0-9]+)(.*) ]]; then
            # Two-node iSCSI disk line: rewrite LUN (and target if needed).
            key="${BASH_REMATCH[1]}"
            rest="${BASH_REMATCH[5]}"
            disknum="${key_to_disknum[$key]}"

            if [[ -n "$disknum" && -n "${disk_to_lun[$disknum]}" ]]; then
                new_lun="${disk_to_lun[$disknum]}"
                new_target="${disk_to_target[$disknum]}"
                new_path="ip-${STORAGE_IP}:3260-iscsi-${new_target}-lun-${new_lun}"
                # Reconstruct line preserving everything except the path
                prefix="${line%%ip-*}"
                echo "${prefix}${new_path}${rest}"
                echo "  ✓ Rewrote ${key} → LUN ${new_lun}" >&2
            else
                log_msg "WARN: Could not map ${key}, keeping original line"
                echo "$line"
            fi
        elif [[ "$rewrite_needed" == "true" && "$line" =~ ^vmgenid: ]]; then
            echo "vmgenid: $new_vmgenid"
            vmgenid_written=true
        elif [[ "$rewrite_needed" == "true" && "$line" =~ ^smbios1: ]]; then
            echo "smbios1: uuid=${new_smbios_uuid}"
            smbios1_written=true
        else
            echo "$line"
        fi
    done <<< "$archived_content" > "$dest_config"

    if [[ "$rewrite_needed" == "true" ]]; then
        [[ "$vmgenid_written" == "true" ]] || echo "vmgenid: $new_vmgenid" >> "$dest_config"
        [[ "$smbios1_written" == "true" ]] || echo "smbios1: uuid=${new_smbios_uuid}" >> "$dest_config"
    fi

    echo "  ✓ Config restored: $dest_config"
fi

echo ""

# =======================================================================
# Step 4: Rescan (two-node only)
# =======================================================================

if is_two_node; then
    echo "--- Step 4: Rescanning iSCSI ---"
    "$mydir/rescan-storage"
    echo ""
fi

# =======================================================================
# Done

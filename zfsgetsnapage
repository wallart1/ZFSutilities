#!/usr/bin/bash
# Return the age of a ZFS snapshot in days.
# $1 = snapshot name (e.g. threeamigos/proxmox/vm-101-disk-0@dailybackup-2026-03-10T02:00-06:00-d)

source ~/bashinit

function getsnapage {
    bashinit
    local snap="$1"

    if [[ -z "$snap" ]]; then
        log_msg "FATAL: Usage: zfsgetsnapage <snapshot>"
        exit 8
    fi

    local creation
    creation=$(zfs get -H -p -o value creation "$snap" 2>/dev/null)
    if [[ -z "$creation" ]]; then
        log_msg "FATAL: Snapshot not found: $snap"
        exit 8
    fi

    local now
    now=$(date +%s)
    local age_days=$(( (now - creation) / 86400 ))
    echo "$age_days"
}
if calledbybash; then getsnapage "$1"; fi

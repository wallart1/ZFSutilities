#!/usr/bin/bash
# rescan-storage
# Rescans iSCSI sessions so the compute host discovers new/changed/removed LUNs.
#
# Install to: /usr/local/lib/zfsutilities/bin/rescan-storage on BOTH the storage and compute hosts
# Run from:   the compute host (or the storage host directly — delegates via SSH)

source ~/bashinit
bashinit
NODE_LIB="${NODE_LIB:-$(find_zfsutility_script node-lib.sh)}"
source "$NODE_LIB"
source "$(find_zfsutility_script rootcheck)"
rootcheck

MY_HOST=$(hostname -s)

if is_single_node; then
    echo "rescan-storage: not applicable in single-node mode (no iSCSI)"
    exit 0
fi

# --- If not on the compute host, delegate via SSH ---
if [[ "$MY_HOST" != "$COMPUTE_HOST" ]]; then
    REMOTE_SCRIPT=$(remote_zfsutility_script "$COMPUTE_HOST" "rescan-storage")
    exec ssh root@"$COMPUTE_HOST" "$REMOTE_SCRIPT"
fi

# === Running on the compute host ===

echo "=== rescan-storage ==="

# --- Check iSCSI sessions ---
SESSION_COUNT=$(iscsiadm -m session 2>/dev/null | wc -l)
if [[ "$SESSION_COUNT" -eq 0 ]]; then
    log_msg "FATAL: No active iSCSI sessions — storage network may be down"
    log_msg "FATAL:   Run: sudo diagnose-storage"
    exit 1
fi

echo "Active iSCSI sessions: $SESSION_COUNT"
iscsiadm -m session 2>/dev/null | sed 's/^/  /'
echo ""

# --- Rescan all sessions ---
echo "Rescanning iSCSI sessions..."
iscsiadm -m session --rescan 2>&1 | sed 's/^/  /'
echo "✓ Rescan complete"

# --- Show device count ---
DEVICE_COUNT=$(ls /dev/disk/by-path/ip-${STORAGE_IP}* 2>/dev/null | wc -l)
echo ""
echo "Total iSCSI devices visible: $DEVICE_COUNT"

if [[ "$DEVICE_COUNT" -lt 31 ]]; then
    log_msg "WARN: Expected at least 31 devices (29 threeamigos + 2 nvme1)"
    log_msg "WARN:   Current count ($DEVICE_COUNT) is low — some LUNs may be missing"
fi

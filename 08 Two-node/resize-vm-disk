#!/bin/bash
# resize-vm-disk <pool> <vmid> <disk-num> <new-size>
# Grows a zvol and triggers a rescan so the compute host sees the new size.
#
# Install to: /usr/local/lib/zfsutilities/bin/resize-vm-disk on BOTH the storage and compute hosts
# Run from:   the compute host (or the storage host directly — delegates via SSH)
#
# NOTE: ZFS supports online growth only. Shrinking is not supported.

source /usr/local/lib/node-lib.sh

MY_HOST=$(hostname -s)

usage() {
    local pool_choices
    if is_two_node; then
        pool_choices=$(pool_list | paste -sd '|' -)
    else
        pool_choices=$(zpool list -H -o name 2>/dev/null | paste -sd '|' -)
    fi
    echo "Usage: resize-vm-disk <pool> <vmid> <disk-num> <new-size>"
    echo ""
    echo "  pool      ZFS pool name (${pool_choices})"
    echo "  vmid      Proxmox VM ID"
    echo "  disk-num  Disk number"
    echo "  new-size  TOTAL size after resize — not an increment (e.g. 200G, 1T)"
    echo ""
    echo "  NOTE: Specify the final size you want, not the amount to add."
    echo "        This is different from the Proxmox GUI, which asks for an increment."
    echo "        ZFS only supports growing, not shrinking."
    echo ""
    echo "  To find the current size first: sudo list-vm-disks"
    echo ""
    echo "Example: disk is currently 100G, you want it to be 200G:"
    echo "  resize-vm-disk threeamigos 300 1 200G"
    exit 1
}

die() {
    echo "✗ ERROR: $*" >&2
    exit 1
}

# Filter --skip-rescan from args
SKIP_RESCAN=false
CLEAN_ARGS=()
for arg in "$@"; do
    [[ "$arg" == "--skip-rescan" ]] && SKIP_RESCAN=true || CLEAN_ARGS+=("$arg")
done
set -- "${CLEAN_ARGS[@]}"

# --- Argument validation ---
[[ $# -eq 4 ]] || usage

POOL="$1"
VMID="$2"
DISKNUM="$3"
NEWSIZE="$4"

if is_two_node; then
    is_known_pool "$POOL" || \
        die "Pool must be one of: $(pool_list | paste -sd ' ' -). Got: $POOL"
else
    zpool list -H -o name "$POOL" >/dev/null 2>&1 || \
        die "Pool '$POOL' not found. Available pools: $(zpool list -H -o name 2>/dev/null | paste -sd ' ' -)"
fi
[[ "$VMID" =~ ^[0-9]+$ ]] || die "VMID must be a number, got: $VMID"
[[ "$DISKNUM" =~ ^[0-9]+$ ]] || die "disk-num must be a number, got: $DISKNUM"
[[ "$NEWSIZE" =~ ^[0-9]+(\.[0-9]+)?[KMGTP]$ ]] || \
    die "new-size must be a total size like 200G or 1T (not an increment), got: $NEWSIZE"

[[ $EUID -eq 0 ]] || die "Must run as root (use sudo)"

# --- If not on the storage host, delegate storage work via SSH (two-node only) ---
if is_two_node && [[ "$MY_HOST" != "$STORAGE_HOST" ]]; then
    echo "Connecting to $STORAGE_HOST for storage operations..."
    ssh root@"$STORAGE_HOST" "/usr/local/lib/zfsutilities/bin/resize-vm-disk '$POOL' '$VMID' '$DISKNUM' '$NEWSIZE' --skip-rescan" \
        || die "Storage operations failed on $STORAGE_HOST"
    echo ""
    echo "Rescanning iSCSI on $(hostname)..."
    if [[ "$MY_HOST" == "$COMPUTE_HOST" ]]; then
        /usr/local/lib/zfsutilities/bin/rescan-storage
    else
        ssh root@"$COMPUTE_HOST" "/usr/local/lib/zfsutilities/bin/rescan-storage" 2>&1 \
            || echo "⚠ Could not rescan $COMPUTE_HOST — run 'sudo rescan-storage' on $COMPUTE_HOST manually"
    fi
    exit 0
fi

# === Running on the storage host ===

ZVOL_NAME="$POOL/proxmox/vm-${VMID}-disk-${DISKNUM}"

echo "=== resize-vm-disk ==="
echo "  Zvol:       $ZVOL_NAME"
echo "  Total size: $NEWSIZE  (this is the final size, not an increment)"
echo ""

# --- Check zvol exists ---
if ! zfs list -H -o name "$ZVOL_NAME" 2>/dev/null | grep -q .; then
    die "Zvol does not exist: $ZVOL_NAME"
fi

CURRENT_SIZE=$(zfs get -H -o value volsize "$ZVOL_NAME")
echo "  Current size: $CURRENT_SIZE"
echo ""

# --- Grow zvol ---
echo "Resizing zvol to $NEWSIZE..."
zfs set volsize="$NEWSIZE" "$ZVOL_NAME"
echo "✓ Zvol resized"

NEW_ACTUAL=$(zfs get -H -o value volsize "$ZVOL_NAME")
echo "  New size: $NEW_ACTUAL"

# --- Trigger rescan on the compute host (two-node only, unless called remotely) ---
if is_two_node && [[ "$SKIP_RESCAN" == false ]]; then
    echo "Triggering iSCSI rescan on $COMPUTE_HOST..."
    if ssh -o ConnectTimeout=10 root@"$COMPUTE_HOST" "/usr/local/lib/zfsutilities/bin/rescan-storage" 2>&1; then
        echo "✓ Rescan triggered"
    else
        echo "⚠ Could not reach $COMPUTE_HOST — run 'sudo rescan-storage' on $COMPUTE_HOST manually"
    fi
fi

echo ""
echo "=== Done ==="
echo "  $ZVOL_NAME"
echo "  Before: $CURRENT_SIZE  →  After: $NEW_ACTUAL"
echo ""
echo "Next steps inside the VM:"
echo "  Resize the partition and filesystem (growpart, resize2fs, etc.)"

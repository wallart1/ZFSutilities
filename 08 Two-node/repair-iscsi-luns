#!/usr/bin/bash
# repair-iscsi-luns
# Idempotent repair of iSCSI LUN export on the storage host.
#
# 1. Reads /etc/rtslib-fb-target/expected-backstores.txt (the authoritative
#    manifest) and ensures every backstore listed there is exported as an iSCSI
#    backstore + LUN mapping.
# 2. Preserves existing LUN indexes so working VMs are not disrupted.
# 3. Reports zvols that exist but are not in the manifest without exporting
#    them, so intentionally detached disks stay detached.
# 4. Always rescans the compute host so newly added or existing-but-unseen
#    LUNs appear.
# 5. Optionally re-logs iSCSI sessions if a rescan alone does not reveal all
#    expected LUNs (use --force-relogin; this briefly disconnects all LUNs).
#
# Usage: sudo repair-iscsi-luns [--dry-run] [--force-relogin]
# Install to: /usr/local/lib/zfsutilities/bin/repair-iscsi-luns on the storage host

source ~/bashinit
bashinit

NODE_LIB="${REPAIR_ISCSI_LUNS_NODE_LIB:-$(find_zfsutility_script node-lib.sh)}"
source "$NODE_LIB"

source "$(find_zfsutility_script rootcheck)"
rootcheck

# iSCSI-only script — exit silently in single-node mode
is_single_node && exit 0

MY_HOST=$(hostname -s)

usage() {
    echo "Usage: repair-iscsi-luns [--dry-run] [--force-relogin]"
    echo ""
    echo "  --dry-run         Report what would be changed without making changes"
    echo "  --force-relogin   Re-log iSCSI sessions if rescan does not reveal all LUNs"
    echo "                    (briefly disconnects all LUNs on the compute host)"
    exit 1
}

DRY_RUN=false
FORCE_RELOGIN=false
for arg in "$@"; do
    case "$arg" in
        --dry-run)       DRY_RUN=true ;;
        --force-relogin) FORCE_RELOGIN=true ;;
        -h|--help)       usage ;;
        *)
            log_msg "FATAL: Unknown option: $arg"
            usage
            ;;
    esac
done

# Verify we're on the storage host
if [[ "$MY_HOST" != "$STORAGE_HOST" ]]; then
    log_msg "FATAL: Must run on the storage host ($STORAGE_HOST), not $MY_HOST"
    exit 1
fi

[[ $EUID -eq 0 ]] || [[ "${REPAIR_ISCSI_LUNS_SKIP_ROOT:-}" == "Y" ]] || {
    log_msg "FATAL: Must run as root (use sudo)"
    exit 1
}

SAVEFILE="/etc/rtslib-fb-target/saveconfig.json"
MANIFEST="${REPAIR_ISCSI_LUNS_MANIFEST:-/etc/rtslib-fb-target/expected-backstores.txt}"

# Helper scripts live in the same directory as this script. Override paths are
# provided so unit tests can substitute mocks.
SAFE_ISCSI_SAVE="${REPAIR_ISCSI_SAFE_ISCSI_SAVE:-$mydir/safe-iscsi-save}"
RESCAN_STORAGE="${REPAIR_ISCSI_RESCAN_STORAGE:-$mydir/rescan-storage}"

# ------------------------------------------------------------------
# Target state discovery
# ------------------------------------------------------------------

# Parse targetcli backstore list into a newline-separated list of:
#   backstore_name device_path
# Output variables:
#   _bs_names[]      array of backstore names
#   _bs_devs[name]   associative array of device paths
parse_backstores() {
    _bs_names=()
    unset -v _bs_devs
    declare -gA _bs_devs=()

    local raw
    raw=$(targetcli /backstores/block ls 2>/dev/null) || return 0

    local line name dev
    while IFS= read -r line; do
        # Match lines like:
        #   o- vm-101-disk-0 ........ [/dev/zvol/threeamigos/proxmox/vm-101-disk-0 (1.0MiB) ...]
        if [[ "$line" =~ ^[[:space:]]+o-\ (vm-[0-9]+-disk-[0-9]+)[[:space:]].*\[(/dev/zvol/[^[:space:]]+) ]]; then
            name="${BASH_REMATCH[1]}"
            dev="${BASH_REMATCH[2]}"
            _bs_names+=("$name")
            _bs_devs["$name"]="$dev"
        fi
    done <<< "$raw"
}

# Parse targetcli LUN list for a given target IQN.
# Output variables:
#   _lun_indexes[name]   associative array: backstore name -> LUN index
#   _used_indexes[]      sorted array of indexes already in use
parse_target_luns() {
    local iqn="$1"
    _used_indexes=()
    unset -v _lun_indexes
    declare -gA _lun_indexes=()

    local raw
    raw=$(targetcli "/iscsi/${iqn}/tpg1/luns" ls 2>/dev/null) || return 0

    local line idx name
    while IFS= read -r line; do
        # Match lines like:
        #   | o- lun19 ..... [block/vm-207-disk-2 (/dev/zvol/...) (...)]
        if [[ "$line" =~ lun([0-9]+)[[:space:]].*block/(vm-[0-9]+-disk-[0-9]+) ]]; then
            idx="${BASH_REMATCH[1]}"
            name="${BASH_REMATCH[2]}"
            _lun_indexes["$name"]="$idx"
            _used_indexes+=("$idx")
        fi
    done <<< "$raw"
}

# Discover all VM zvols in configured pools.
# Output variable: _zvols[] array of "pool/dataset" strings.
discover_zvols() {
    _zvols=()
    local pool
    while IFS= read -r pool; do
        [[ -z "$pool" ]] && continue
        local ds
        while IFS= read -r ds; do
            [[ -z "$ds" ]] && continue
            _zvols+=("$ds")
        done < <(zfs list -H -o name -r "${pool}/proxmox" 2>/dev/null \
                 | grep -E '^[^/]+/proxmox/vm-[0-9]+-disk-[0-9]+$')
    done < <(pool_list)
}

# ------------------------------------------------------------------
# Manifest handling
# ------------------------------------------------------------------

# Read the authoritative expected-backstores manifest.
# Output variables:
#   _expected_bs_names[]   array of backstore names that should be exported
#   _expected_bs[name]     associative array for fast membership tests
#   _manifest_exists       true if the manifest file exists, false otherwise
# If the manifest is missing, _expected_bs_names will be empty and callers
# should fall back to another source (e.g. discovered zvols). An empty but
# existing manifest is authoritative: nothing should be exported.
read_manifest() {
    _expected_bs_names=()
    unset -v _expected_bs
    declare -gA _expected_bs=()
    _manifest_exists=false

    if [[ ! -f "$MANIFEST" ]]; then
        return 0
    fi

    _manifest_exists=true

    local name
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        [[ "$name" == \#* ]] && continue
        if [[ "$name" =~ ^vm-[0-9]+-disk-[0-9]+$ ]]; then
            _expected_bs_names+=("$name")
            _expected_bs["$name"]="1"
        fi
    done < "$MANIFEST"
}

# Return 0 if the given backstore name is in the expected manifest.
is_expected_backstore() {
    [[ -n "${_expected_bs[${1}]:-}" ]]
}

# Find the pool/dataset path for a backstore name from the discovered zvols.
# Output: prints the zvol path, or nothing if not found.
find_zvol_for_backstore() {
    local name="$1"
    local zvol
    for zvol in "${_zvols[@]}"; do
        if [[ "${zvol##*/}" == "$name" ]]; then
            echo "$zvol"
            return 0
        fi
    done
    return 1
}

# ------------------------------------------------------------------
# Repair actions
# ------------------------------------------------------------------

# Compute the next free LUN index for a target, given the used indexes.
next_free_lun_index() {
    local idx=0
    local used_sorted
    used_sorted=$(printf '%s\n' "${_used_indexes[@]}" | sort -n)
    while IFS= read -r used; do
        [[ -z "$used" ]] && continue
        if [[ "$idx" -lt "$used" ]]; then
            break
        fi
        idx=$((idx + 1))
    done <<< "$used_sorted"
    echo "$idx"
}

# Create a backstore for a zvol if it does not exist.
# Arguments: name dev_path pool
# Returns 0 on success or if already exists.
create_backstore() {
    local name="$1" dev="$2"
    if [[ -n "${_bs_devs[$name]:-}" ]]; then
        log_msg "INFO: Backstore $name already exists"
        return 0
    fi

    if [[ "$DRY_RUN" == true ]]; then
        log_msg "INFO: [dry-run] Would create backstore $name -> $dev"
        return 0
    fi

    if targetcli /backstores/block create "$name" "$dev" >/dev/null 2>&1; then
        targetcli "/backstores/block/${name}" set attribute emulate_tpu=1 >/dev/null 2>&1
        echo "  ✓ Created backstore $name -> $dev"
        _bs_names+=("$name")
        _bs_devs["$name"]="$dev"
        return 0
    fi

    log_msg "FATAL: Failed to create backstore $name"
    return 1
}

# Create a LUN mapping for a backstore if it is not already mapped.
# Arguments: name iqn
# Uses and updates _used_indexes and _lun_indexes.
create_lun_mapping() {
    local name="$1" iqn="$2"
    if [[ -n "${_lun_indexes[$name]:-}" ]]; then
        log_msg "INFO: LUN mapping for $name already exists (${_lun_indexes[$name]}): $name"
        return 0
    fi

    local idx
    idx=$(next_free_lun_index)

    if [[ "$DRY_RUN" == true ]]; then
        log_msg "INFO: [dry-run] Would map $name to ${iqn}/tpg1/lun$idx"
        _used_indexes+=("$idx")
        _lun_indexes["$name"]="$idx"
        return 0
    fi

    if targetcli "/iscsi/${iqn}/tpg1/luns" create "/backstores/block/${name}" "$idx" >/dev/null 2>&1; then
        echo "  ✓ Mapped $name to ${iqn}/tpg1/lun$idx"
        _used_indexes+=("$idx")
        _lun_indexes["$name"]="$idx"
        return 0
    fi

    log_msg "FATAL: Failed to map $name to ${iqn}/tpg1/lun$idx"
    return 1
}

# Back up saveconfig.json before mutation.
backup_saveconfig() {
    [[ -f "$SAVEFILE" ]] || return 0
    local backup
    backup="${SAVEFILE}.backup.$(date +%Y%m%d-%H%M%S)"
    cp -f "$SAVEFILE" "$backup"
    log_msg "INFO: Backed up saveconfig.json to $backup"
}

# Regenerate expected-backstores.txt from the current list of loaded backstores.
# This keeps the manifest accurate after adds/moves.
regenerate_manifest() {
    if [[ "$DRY_RUN" == true ]]; then
        log_msg "INFO: [dry-run] Would regenerate $MANIFEST"
        return 0
    fi

    local tmpfile
    tmpfile=$(mktemp)
    {
        echo "# Expected iSCSI backstores - authoritative manifest"
        echo "# Format: one backstore name per line (vm-<vmid>-disk-<N>)"
        echo "# Updated: $(date -Iseconds)"
        echo "# Source: Generated by repair-iscsi-luns from current targetcli state"
        echo ""
        printf '%s\n' "${_bs_names[@]}" | sort -V
    } > "$tmpfile"

    mv -f "$tmpfile" "$MANIFEST"
    echo "  ✓ Regenerated $MANIFEST"
}

# ------------------------------------------------------------------
# Compute host visibility
# ------------------------------------------------------------------

# Count how many iSCSI by-path devices are visible on the compute host.
count_visible_devices() {
    ssh -o ConnectTimeout=10 root@"$COMPUTE_HOST" \
        "ls /dev/disk/by-path/ip-${STORAGE_IP}* 2>/dev/null | wc -l" 2>/dev/null
}

# Rescan the compute host. Always runs.
rescan_compute_host() {
    log_msg "INFO: Rescanning compute host ($COMPUTE_HOST)..."
    if [[ "$DRY_RUN" == true ]]; then
        log_msg "INFO: [dry-run] Would run rescan-storage on $COMPUTE_HOST"
        return 0
    fi

    if ! type -t "$RESCAN_STORAGE" >/dev/null 2>&1; then
        log_msg "WARN: rescan-storage not available at $RESCAN_STORAGE"
        return 1
    fi

    if "$RESCAN_STORAGE"; then
        echo "  ✓ Compute host rescan complete"
    else
        log_msg "WARN: Compute host rescan returned non-zero"
    fi
}

# Re-log iSCSI sessions on the compute host.
# This briefly disconnects all LUNs and should be used with care.
relogin_compute_host() {
    log_msg "WARN: Re-logging iSCSI sessions on $COMPUTE_HOST (all LUNs will briefly disconnect)"
    if [[ "$DRY_RUN" == true ]]; then
        log_msg "INFO: [dry-run] Would re-log iSCSI sessions"
        return 0
    fi

    ssh -o ConnectTimeout=10 root@"$COMPUTE_HOST" bash -s -- "$STORAGE_IP" <<'SSHEOF'
        STORAGE_IP="$1"
        iscsiadm -m node -p "${STORAGE_IP}:3260" -u
        sleep 1
        iscsiadm -m node -p "${STORAGE_IP}:3260" -l
SSHEOF

    echo "  ✓ Re-login complete"
}

# ------------------------------------------------------------------
# Main
# ------------------------------------------------------------------

main() {

echo "=== repair-iscsi-luns ==="
echo ""

# Gather current target state
parse_backstores
log_msg "INFO: Loaded backstores: ${#_bs_names[@]}"

# Gather zvols and expected state
discover_zvols
log_msg "INFO: Discovered VM zvols: ${#_zvols[@]}"

# Read the authoritative manifest. If it is missing, fall back to the
# discovered zvol list so legacy or newly-initialized systems still get repaired.
# An existing but empty manifest is authoritative and means nothing is expected.
read_manifest
if [[ "${_manifest_exists}" == true ]]; then
    log_msg "INFO: Expected backstores from manifest: ${#_expected_bs_names[@]}"
elif [[ ${#_zvols[@]} -gt 0 ]]; then
    log_msg "WARN: Manifest missing; falling back to discovered zvols"
    for zvol in "${_zvols[@]}"; do
        _expected_bs_names+=("${zvol##*/}")
        _expected_bs["${zvol##*/}"]="1"
    done
    log_msg "INFO: Expected backstores from zvols: ${#_expected_bs_names[@]}"
fi
echo ""

# Track whether we made any target-side changes
TARGET_CHANGED=false
MISSING_BACKSTORES=()
MISSING_LUNS=()
UNMAPPED_ZVOLS=()

# Ensure each expected backstore has a backstore and a LUN mapping.
for bs_name in "${_expected_bs_names[@]}"; do
    [[ -z "$bs_name" ]] && continue

    zvol=$(find_zvol_for_backstore "$bs_name") || true
    if [[ -z "$zvol" ]]; then
        log_msg "WARN: Expected backstore $bs_name has no corresponding zvol (skipping)"
        continue
    fi

    # Extract pool and build the device path / IQN for this zvol
    zvol_pool="${zvol%%/*}"
    zvol_dev="/dev/zvol/${zvol}"
    zvol_iqn=$(pool_to_target "$zvol_pool") || continue

    if [[ ! -e "$zvol_dev" ]] && [[ "${REPAIR_ISCSI_LUNS_TEST_MODE:-}" != "Y" ]]; then
        log_msg "WARN: Device not available: $zvol_dev (skipping $bs_name)"
        continue
    fi

    # Make sure target LUN state is loaded for this pool
    parse_target_luns "$zvol_iqn"

    if [[ -z "${_bs_devs[$bs_name]:-}" ]]; then
        MISSING_BACKSTORES+=("$bs_name")
        if create_backstore "$bs_name" "$zvol_dev"; then
            TARGET_CHANGED=true
        fi
    fi

    if [[ -z "${_lun_indexes[$bs_name]:-}" ]]; then
        MISSING_LUNS+=("$bs_name")
        if create_lun_mapping "$bs_name" "$zvol_iqn"; then
            TARGET_CHANGED=true
        fi
    fi
done

# Find loaded backstores that are not mapped to any LUN (limit to manifest
# entries so detached/orphaned backstores are not silently re-mapped).
for bs_name in "${_bs_names[@]}"; do
    [[ -z "$bs_name" ]] && continue
    is_expected_backstore "$bs_name" || continue

    # Determine which target this backstore belongs to from its device path
    bs_dev="${_bs_devs[$bs_name]}"
    bs_pool=""
    if [[ "$bs_dev" =~ /dev/zvol/([^/]+)/proxmox/ ]]; then
        bs_pool="${BASH_REMATCH[1]}"
    fi
    [[ -z "$bs_pool" ]] && continue

    bs_iqn=$(pool_to_target "$bs_pool") || continue
    parse_target_luns "$bs_iqn"

    if [[ -z "${_lun_indexes[$bs_name]:-}" ]]; then
        MISSING_LUNS+=("$bs_name")
        if create_lun_mapping "$bs_name" "$bs_iqn"; then
            TARGET_CHANGED=true
        fi
    fi
done

# Find zvols that exist but are not in the expected manifest. These are
# intentionally detached or otherwise not meant to be exported.
for zvol in "${_zvols[@]}"; do
    zvol_name="${zvol##*/}"
    if ! is_expected_backstore "$zvol_name"; then
        UNMAPPED_ZVOLS+=("$zvol")
    fi
done

# Report unexported zvols (do not auto-export; use attach-vm-disk/new-vm-disk).
if [[ ${#UNMAPPED_ZVOLS[@]} -gt 0 ]]; then
    echo ""
    log_msg "WARN: The following zvols exist but are not in the expected manifest:"
    for zvol in "${UNMAPPED_ZVOLS[@]}"; do
        echo "    $zvol"
    done
    echo "  (They will not be exported. Use attach-vm-disk or new-vm-disk when you want to use them.)"
fi

# Persist changes
if [[ "$TARGET_CHANGED" == true ]]; then
    echo ""
    if [[ "$DRY_RUN" == true ]]; then
        log_msg "INFO: [dry-run] Would back up saveconfig.json, regenerate manifest, and save config"
    else
        backup_saveconfig
        regenerate_manifest
        if type -t "$SAFE_ISCSI_SAVE" >/dev/null 2>&1; then
            if "$SAFE_ISCSI_SAVE"; then
                echo "  ✓ iSCSI configuration saved"
            else
                log_msg "FATAL: safe-iscsi-save failed — configuration may not be persistent"
            fi
        else
            log_msg "FATAL: safe-iscsi-save not available at $SAFE_ISCSI_SAVE — configuration may not be persistent"
        fi
    fi
else
    echo ""
    log_msg "INFO: No target-side changes needed"
    if [[ "$DRY_RUN" != true ]]; then
        regenerate_manifest
    fi
fi

# Compute-side repair: always rescan, optionally re-login if requested/needed
echo ""
VISIBLE_BEFORE=$(count_visible_devices)
log_msg "INFO: Visible iSCSI devices on $COMPUTE_HOST before rescan: ${VISIBLE_BEFORE:-?}"

rescan_compute_host

VISIBLE_AFTER=$(count_visible_devices)
log_msg "INFO: Visible iSCSI devices on $COMPUTE_HOST after rescan: ${VISIBLE_AFTER:-?}"

if [[ "$FORCE_RELOGIN" == true ]] && [[ "${VISIBLE_AFTER:-0}" -le "${VISIBLE_BEFORE:-0}" ]]; then
    echo ""
    log_msg "WARN: Device count did not increase after rescan; attempting re-login"
    relogin_compute_host
    VISIBLE_AFTER=$(count_visible_devices)
    log_msg "INFO: Visible iSCSI devices after re-login: ${VISIBLE_AFTER:-?}"
fi

# Summary
echo ""
echo "=== Summary ==="
if [[ ${#MISSING_BACKSTORES[@]} -gt 0 ]]; then
    echo "  ✓ Backstores added/verified: ${#MISSING_BACKSTORES[@]}"
fi
if [[ ${#MISSING_LUNS[@]} -gt 0 ]]; then
    echo "  ✓ LUN mappings added/verified: ${#MISSING_LUNS[@]}"
fi
if [[ ${#UNMAPPED_ZVOLS[@]} -gt 0 ]]; then
    log_msg "WARN: Unexported zvols: ${#UNMAPPED_ZVOLS[@]}"
fi
log_msg "INFO: Visible devices on $COMPUTE_HOST: ${VISIBLE_AFTER:-?}"
echo "  ✓ Done"
echo ""

} # end main

# Run main only when executed directly, not when sourced for tests.
if [[ -z "${REPAIR_ISCSI_LUNS_TEST_MODE:-}" ]] && [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main
fi

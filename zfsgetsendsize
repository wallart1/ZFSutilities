#!/usr/bin/bash
# Get the actual size to send
source ~/bashinit
bashinit

if [[ $1 = '' ]]; then
    log_msg 'WARN: A snapshot must be given.'
fi

# For parseable format:
if ! sendsize=$(zfs send -nPc $1 | awk '{if (NR > 1) printf "\n"; printf "%s", $3}'); then
    unset sendsize
    log_msg "WARN: Unable to get send size for $1."
    echo ''
else
    # For human-readable format:
    sendsize_h=$(echo $sendsize | numfmt --to=iec-i)
    echo "$sendsize $sendsize_h"
fi

